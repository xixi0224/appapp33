page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 计划生成器 */
.generator {
  padding: 40rpx 20rpx;
}

.generator-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.generator-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 15rpx;
}

.generator-subtitle {
  font-size: 24rpx;
  color: #999999;
  display: block;
}

.form-section {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 15rpx;
}

.picker-value {
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #333333;
}

.picker-value.placeholder {
  color: #999999;
}

.textarea-input {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.text-input {
  width: 100%;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.slider-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.slider-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #667eea;
  margin-top: 15rpx;
}

.generate-button {
  width: 100%;
  padding: 25rpx;
  background-color: #667eea;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  border-radius: 15rpx;
  margin-top: 30rpx;
}

.generate-button:active {
  background-color: #5a6fe0;
  transform: scale(0.98);
}

.generate-button.disabled {
  background-color: #a0a0a0;
  color: #e0e0e0;
  pointer-events: none;
}

/* 学习计划列表 */
.plan-view {
  padding: 20rpx;
}

.plan-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 30rpx;
  color: #ffffff;
}

.plan-info {
  margin-bottom: 24rpx;
}

.plan-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.plan-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  display: block;
}

.progress-container {
  display: flex;
  align-items: center;
}

.progress-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-right: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 16rpx;
  background-color: rgba(255,255,255,0.25);
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #ffffff;
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-value {
  font-size: 24rpx;
  font-weight: bold;
  color: #ffffff;
  margin-left: 16rpx;
}

/* 每日卡片竖向列表 */
.day-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.day-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  border-left: 8rpx solid #e0e0e0;
}

.day-card.today {
  border-left-color: #667eea;
  background: linear-gradient(135deg, #f0f3ff 0%, #ffffff 100%);
}

.day-card.completed {
  border-left-color: #52c41a;
  background-color: #f9fff9;
}

.day-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.day-left {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.day-date {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.day-weekday {
  font-size: 24rpx;
  color: #999999;
}

.day-status {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  background-color: #f5f5f5;
}

.day-status.today {
  background-color: #667eea;
}

.day-status.completed {
  background-color: #52c41a;
}

.status-text {
  font-size: 22rpx;
  color: #999999;
}

.day-status.today .status-text,
.day-status.completed .status-text {
  color: #ffffff;
}

.tasks-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.task-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 20rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
}

.task-item.completed {
  background-color: #f0f0f0;
}

.task-item.completed .task-text {
  text-decoration: line-through;
  color: #bbbbbb;
}

.task-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid #d9d9d9;
  margin-right: 16rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 2rpx;
}

.task-check.checked {
  background-color: #667eea;
  border-color: #667eea;
}

.check-icon {
  font-size: 20rpx;
  color: #ffffff;
  font-weight: bold;
}

.task-text {
  font-size: 28rpx;
  color: #444444;
  flex: 1;
  line-height: 1.5;
  word-break: break-all;
}

.regenerate-button {
  width: 100%;
  padding: 25rpx;
  background-color: #f5f5f5;
  color: #667eea;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  border-radius: 15rpx;
  margin-top: 30rpx;
}

.check-in-button {
  width: 100%;
  padding: 25rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  border-radius: 15rpx;
  margin-top: 20rpx;
}

.check-in-button:active {
  transform: scale(0.98);
}

/* 深色模式 */
.dark page {
  background-color: #1a1a1a;
}

.dark .generator-title {
  color: #ffffff;
}

.dark .form-section {
  background-color: #2d2d2d;
}

.dark .form-label {
  color: #ffffff;
}

.dark .picker-value {
  background-color: #3d3d3d;
  color: #ffffff;
}

.dark .picker-value.placeholder {
  color: #666666;
}

.dark .day-card {
  background-color: #2d2d2d;
  border-bottom-color: #3d3d3d;
}

.dark .day-card.today {
  background: linear-gradient(135deg, #1e2240 0%, #2d2d2d 100%);
}

.dark .day-card.completed {
  background-color: #1a2e1a;
}

.dark .day-date {
  color: #ffffff;
}

.dark .task-text {
  color: #cccccc;
}

.dark .task-item {
  background-color: #3d3d3d;
}

.dark .task-item.completed {
  background-color: #333333;
}

.dark .task-item.completed .task-text {
  color: #666666;
}

.dark .day-header {
  border-bottom-color: #3d3d3d;
}

.dark .regenerate-button {
  background-color: #3d3d3d;
}
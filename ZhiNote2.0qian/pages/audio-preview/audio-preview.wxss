/* 音频预览页面样式 */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  margin-bottom: 30rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
}

.audio-info {
  background-color: white;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.info-item {
  margin-bottom: 15rpx;
  display: flex;
  align-items: center;
}

.label {
  font-size: 28rpx;
  color: #666;
  width: 120rpx;
}

.value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}

.audio-player {
  background-color: white;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.player-controls {
  display: flex;
  align-items: center;
}

.play-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #1890ff;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  border: none;
}

.play-icon {
  font-size: 40rpx;
}

.progress-container {
  flex: 1;
  display: flex;
  align-items: center;
}

.time {
  font-size: 24rpx;
  color: #666;
  width: 80rpx;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background-color: #e8e8e8;
  border-radius: 4rpx;
  margin: 0 15rpx;
  position: relative;
}

.progress {
  height: 100%;
  background-color: #1890ff;
  border-radius: 4rpx;
  position: absolute;
  top: 0;
  left: 0;
}

.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn {
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn.primary {
  background-color: #1890ff;
  color: white;
}

.btn.secondary {
  background-color: #f0f0f0;
  color: #333;
}

/* 深色模式 */
page.dark {
  background-color: #1f1f1f;
  color: #ffffff;
}

page.dark .container {
  background-color: #1f1f1f;
}

page.dark .audio-info,
page.dark .audio-player {
  background-color: #2f2f2f;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

page.dark .title,
page.dark .value {
  color: #ffffff;
}

page.dark .label,
page.dark .time {
  color: #999999;
}

page.dark .progress-bar {
  background-color: #444444;
}

page.dark .btn.secondary {
  background-color: #333333;
  color: #ffffff;
}
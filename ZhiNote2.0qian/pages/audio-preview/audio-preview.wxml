<view class="container">
  <view class="header">
    <text class="title">音频预览</text>
  </view>
  
  <view class="audio-info">
    <view class="info-item">
      <text class="label">文件名：</text>
      <text class="value">{{audioInfo.name}}</text>
    </view>
    <view class="info-item">
      <text class="label">文件大小：</text>
      <text class="value">{{audioInfo.size}}</text>
    </view>
    <view class="info-item">
      <text class="label">时长：</text>
      <text class="value">{{audioInfo.duration}}</text>
    </view>
  </view>
  
  <view class="audio-player">
    <view class="player-controls">
      <button class="play-btn" bindtap="togglePlay">
        <text class="play-icon">{{isPlaying ? '⏸' : '▶'}}</text>
      </button>
      <view class="progress-container">
        <text class="time">{{currentTime}}</text>
        <view class="progress-bar">
          <view class="progress" style="width: {{progress}}%"></view>
        </view>
        <text class="time">{{totalDuration}}</text>
      </view>
    </view>
  </view>
  
  <view class="action-buttons">
    <button class="btn primary" bindtap="goToTranscribe">
      转文字
    </button>
    <button class="btn secondary" bindtap="onBack">
      返回
    </button>
  </view>
</view>
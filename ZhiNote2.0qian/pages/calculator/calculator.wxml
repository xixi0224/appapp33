<view class="container">
  <!-- 显示屏 -->
  <view class="display">
    <text class="expression">{{expression}}</text>
    <text class="result">{{result}}</text>
  </view>
  
  <!-- 科学功能键 -->
  <view class="scientific-keys">
    <button class="sci-key" bindtap="inputScientific" data-value="sin">sin</button>
    <button class="sci-key" bindtap="inputScientific" data-value="cos">cos</button>
    <button class="sci-key" bindtap="inputScientific" data-value="tan">tan</button>
    <button class="sci-key" bindtap="inputScientific" data-value="log">log</button>
    <button class="sci-key" bindtap="inputScientific" data-value="ln">ln</button>
    <button class="sci-key" bindtap="inputScientific" data-value="sqrt">√</button>
    <button class="sci-key" bindtap="inputScientific" data-value="^">^</button>
    <button class="sci-key" bindtap="inputScientific" data-value="π">π</button>
  </view>
  
  <!-- 基本功能键 -->
  <view class="basic-keys">
    <view class="key-row">
      <button class="key function" bindtap="clear">AC</button>
      <button class="key function" bindtap="delete">DEL</button>
      <button class="key function" bindtap="inputOperator" data-value="%">%</button>
      <button class="key operator" bindtap="inputOperator" data-value="/">÷</button>
    </view>
    
    <view class="key-row">
      <button class="key number" bindtap="inputNumber" data-value="7">7</button>
      <button class="key number" bindtap="inputNumber" data-value="8">8</button>
      <button class="key number" bindtap="inputNumber" data-value="9">9</button>
      <button class="key operator" bindtap="inputOperator" data-value="*">×</button>
    </view>
    
    <view class="key-row">
      <button class="key number" bindtap="inputNumber" data-value="4">4</button>
      <button class="key number" bindtap="inputNumber" data-value="5">5</button>
      <button class="key number" bindtap="inputNumber" data-value="6">6</button>
      <button class="key operator" bindtap="inputOperator" data-value="-">−</button>
    </view>
    
    <view class="key-row">
      <button class="key number" bindtap="inputNumber" data-value="1">1</button>
      <button class="key number" bindtap="inputNumber" data-value="2">2</button>
      <button class="key number" bindtap="inputNumber" data-value="3">3</button>
      <button class="key operator" bindtap="inputOperator" data-value="+">+</button>
    </view>
    
    <view class="key-row">
      <button class="key number" bindtap="inputNumber" data-value="0">0</button>
      <button class="key number" bindtap="inputNumber" data-value=".">.</button>
      <button class="key function" bindtap="toggleSign">±</button>
      <button class="key equals" bindtap="equals">=</button>
    </view>
  </view>
</view>
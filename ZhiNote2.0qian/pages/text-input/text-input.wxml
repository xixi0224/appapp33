<view class="container">
  <!-- 自定义导航栏 -->
  <view class="custom-nav-bar">
    <button class="nav-button back" bindtap="goBack">
      <text class="nav-icon">←</text>
    </button>
    <text class="nav-title">新建笔记</text>
    <button class="nav-button complete" bindtap="saveNote">
      <text class="nav-text">完成</text>
    </button>
  </view>
  
  <!-- AI提示条 -->
  <view wx:if="{{showAiTip}}" class="ai-tip">
    <text class="ai-tip-text">检测到长文本，是否需要AI智能分段？</text>
    <view class="ai-tip-buttons">
      <button class="ai-tip-button cancel" bindtap="cancelAiTip">取消</button>
      <button class="ai-tip-button confirm" bindtap="confirmAiTip">确定</button>
    </view>
  </view>
  
  <!-- 标题输入框 -->
  <input 
    class="title-input" 
    placeholder="输入笔记标题（选填）" 
    bindinput="onTitleInput"
    value="{{title}}"
  />
  
  <!-- 文本输入框 -->
  <textarea 
    class="content-input" 
    placeholder="请输入或粘贴你的课堂笔记、讲义内容…" 
    bindinput="onContentInput"
    value="{{content}}"
    auto-height
  />
  
  <!-- 底部工具栏 -->
  <view class="toolbar">
    <view class="toolbar-buttons">
      <button class="toolbar-button" bindtap="insertHeading">
        <text class="toolbar-icon">#</text>
        <text class="toolbar-text">标题</text>
      </button>
      <button class="toolbar-button" bindtap="insertList">
        <text class="toolbar-icon">-</text>
        <text class="toolbar-text">列表</text>
      </button>
      <button class="toolbar-button" bindtap="insertBold">
        <text class="toolbar-icon">B</text>
        <text class="toolbar-text">加粗</text>
      </button>
    </view>
    <view class="word-count">
      <text class="word-count-text">{{wordCount}} 字</text>
    </view>
  </view>
</view>
page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

/* 自定义导航栏 */
.custom-nav-bar {
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  padding: 0 20rpx;
  border-bottom: 1rpx solid #e5e5e5;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-button {
  background: none;
  border: none;
  padding: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-button.back {
  width: 60rpx;
}

.nav-button.complete {
  width: 80rpx;
}

.nav-icon {
  font-size: 32rpx;
  color: #333333;
}

.nav-text {
  font-size: 28rpx;
  color: #1677ff;
  font-weight: bold;
}

.nav-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}


/* AI提示条 */
.ai-tip {
  background-color: #f0f5ff;
  border-bottom: 1rpx solid #e6f0ff;
  padding: 15rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  animation: slideDown 0.3s ease;
}

@keyframes slideDown {
  from {
    transform: translateY(-100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.ai-tip-text {
  font-size: 24rpx;
  color: #1677ff;
  flex: 1;
}

.ai-tip-buttons {
  display: flex;
  margin-left: 20rpx;
}

.ai-tip-button {
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  margin-left: 10rpx;
}

.ai-tip-button.cancel {
  background-color: #ffffff;
  color: #666666;
  border: 1rpx solid #e5e5e5;
}

.ai-tip-button.confirm {
  background-color: #1677ff;
  color: #ffffff;
}

/* 标题输入框 */
.title-input {
  background-color: #ffffff;
  padding: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  border-bottom: 1rpx solid #e5e5e5;
  margin-bottom: 10rpx;
}

/* 文本输入框 */
.content-input {
  flex: 1;
  background-color: #ffffff;
  padding: 20rpx;
  font-size: 28rpx;
  line-height: 40rpx;
  min-height: 600rpx;
  resize: none;
}

/* 底部工具栏 */
.toolbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  border-top: 1rpx solid #e5e5e5;
  padding: 15rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.toolbar-buttons {
  display: flex;
}

.toolbar-button {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-right: 40rpx;
  background: none;
  padding: 0;
}

.toolbar-icon {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 4rpx;
}

.toolbar-text {
  font-size: 20rpx;
  color: #666666;
}

.word-count {
  font-size: 24rpx;
  color: #999999;
}

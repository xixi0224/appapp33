page {
  background: #f7f8fa;
  color: #1f1f1f;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
  padding-top: 20rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1677ff;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #666;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.quick-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.action-item {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
  transition: transform 0.2s;
}

.action-item:active {
  transform: scale(0.95);
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.action-icon.voice {
  background-color: #e6f7ff;
  color: #1677ff;
}

.action-icon.audio {
  background-color: #f6ffed;
  color: #52c41a;
}

.action-icon.text {
  background-color: #fff2e8;
  color: #fa8c16;
}

.action-icon.file {
  background-color: #f9f0ff;
  color: #722ed1;
}

.action-text {
  font-size: 24rpx;
  color: #333;
}

.recent-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
}

.recent-item {
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  cursor: pointer;
  transition: background-color 0.2s;
}

.recent-item:hover {
  background-color: #fafafa;
}

.recent-item:active {
  background-color: #f0f0f0;
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-item-content {
  flex: 1;
  margin-bottom: 10rpx;
}

.recent-item-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.recent-item-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.recent-item-time {
  font-size: 20rpx;
  color: #999;
}

.recent-item-source {
  font-size: 20rpx;
  color: #1677ff;
  background-color: #e6f7ff;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.recent-item-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #f0f5ff;
  color: #1677ff;
  font-size: 20rpx;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 20rpx;
  color: #999;
}

.loading-text {
  font-size: 24rpx;
  text-align: center;
}

.stats-grid {
  display: flex;
  gap: 20rpx;
}

.stat-item {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  text-align: center;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #1677ff;
  margin-bottom: 5rpx;
  display: block;
}

.stat-label {
  font-size: 20rpx;
  color: #666;
}

/* 图标样式 */
.voice::before {
  content: "🎤";
}

.audio::before {
  content: "🎵";
}

.text::before {
  content: "📝";
}

.file::before {
  content: "📁";
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
}

.sub {
  color: #666;
  font-size: 24rpx;
}

.btn-primary {
  background: #1677ff;
  color: #fff;
  border-radius: 16rpx;
}

.btn-ghost {
  background: #eef4ff;
  color: #1677ff;
  border-radius: 16rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #f0f5ff;
  color: #1677ff;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 20rpx;
  color: #999;
}

.empty-text {
  font-size: 24rpx;
  text-align: center;
}
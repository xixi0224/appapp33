<view class="container">
  <view class="header">
    <text class="title">ZhiNote</text>
    <text class="subtitle">智能学习助手</text>
  </view>
  
  <!-- 快速入口 -->
  <view class="section">
    <text class="section-title">快速入口</text>
    <view class="quick-actions">
      <view class="action-item" bindtap="goVoiceInput">
        <view class="action-icon voice"></view>
        <text class="action-text">语音录入</text>
      </view>
      <view class="action-item" bindtap="goAudioUpload">
        <view class="action-icon audio"></view>
        <text class="action-text">音频上传</text>
      </view>
      <view class="action-item" bindtap="goTextInput">
        <view class="action-icon text"></view>
        <text class="action-text">文本输入</text>
      </view>
      <view class="action-item" bindtap="goFileImport">
        <view class="action-icon file"></view>
        <text class="action-text">文件导入</text>
      </view>
    </view>
  </view>
  
  <!-- 最近学习记录 -->
  <view class="section">
    <text class="section-title">最近学习</text>
    <view class="recent-list">
      <block wx:if="{{loading}}">
        <view class="loading-state">
          <text class="loading-text">加载中...</text>
        </view>
      </block>
      <block wx:elif="{{recentNotes.length > 0}}">
        <view 
          wx:for="{{recentNotes}}" 
          wx:key="id" 
          class="recent-item" 
          bindtap="onRecentNoteTap" 
          data-note-id="{{item.id}}" 
          data-title="{{item.title}}"
        >
          <view class="recent-item-content">
            <text class="recent-item-title">{{item.title}}</text>
            <view class="recent-item-meta">
              <text class="recent-item-time">{{item.created_at}}</text>
              <text class="recent-item-source">{{item.source_type}}</text>
            </view>
          </view>
          <view class="recent-item-tags">
            <view wx:for="{{item.tags}}" wx:key="*this" class="tag">{{item}}</view>
          </view>
        </view>
      </block>
      <block wx:else>
        <view class="empty-state">
          <text class="empty-text">暂无学习记录</text>
        </view>
      </block>
    </view>
  </view>
  
  <!-- 学习数据概览 -->
  <view class="section">
    <text class="section-title">学习数据</text>
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-value">0</text>
        <text class="stat-label">学习时长(小时)</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">0</text>
        <text class="stat-label">笔记数量</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">0</text>
        <text class="stat-label">复习次数</text>
      </view>
    </view>
  </view>
</view>
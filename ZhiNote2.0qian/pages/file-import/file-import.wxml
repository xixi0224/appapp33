<view class="container">
  <!-- 拖放区域 -->
  <view wx:if="{{!selectedFile}}" class="drop-area" bindtap="chooseFile">
    <view class="drop-icon">
      <text class="icon-text">📄</text>
    </view>
    <text class="drop-title">点击选择或拖入文档文件</text>
    <text class="drop-subtitle">支持格式：PDF, DOCX, DOC</text>
  </view>
  
  <!-- 文件信息卡片 -->
  <view wx:else class="file-card">
    <view class="file-info">
      <view class="file-icon">
        <text class="icon-text">📄</text>
      </view>
      <view class="file-details">
        <text class="file-name">{{selectedFile.name}}</text>
        <text class="file-size">{{formatFileSize(selectedFile.size)}}</text>
      </view>
    </view>
    <view class="card-buttons">
      <button class="card-button secondary" bindtap="resetFile">重新选择</button>
      <button class="card-button primary" bindtap="nextStep">下一步</button>
    </view>
  </view>
  
  <!-- 课程分类选择页 -->
  <view wx:if="{{showCategorySelect}}" class="category-select">
    <view class="preview-section">
      <text class="section-title">文档预览</text>
      <view class="document-preview">
        <text class="preview-placeholder">点击下方按钮预览文档</text>
        <button class="preview-button" bindtap="previewDocument">预览文档</button>
      </view>
    </view>
    
    <view class="category-section">
      <text class="section-title">选择课程分类</text>
      <view class="category-cards">
        <view 
          wx:for="{{categories}}" 
          wx:key="id"
          class="category-card {{selectedCategory === item.id ? 'selected' : ''}}"
          bindtap="selectCategory"
          data-id="{{item.id}}"
        >
          <text class="category-icon">{{item.icon}}</text>
          <text class="category-name">{{item.name}}</text>
        </view>
      </view>
    </view>
    
    <button 
      class="import-button" 
      bindtap="startImport"
      disabled="{{!selectedCategory}}"
    >
      开始导入
    </button>
  </view>
  
  <!-- 解析加载页 -->
  <view wx:if="{{showLoading}}" class="loading-page">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">正在解析文档内容，请稍候…</text>
      <view class="page-animation">
        <text class="page-number">{{currentPage}} / {{totalPages}}</text>
      </view>
    </view>
  </view>
</view>
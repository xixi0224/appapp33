page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 20rpx;
}

/* 拖放区域 */
.drop-area {
  border: 2rpx dashed #1677ff;
  border-radius: 20rpx;
  padding: 80rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #f0f5ff;
  margin: 40rpx 0;
  cursor: pointer;
  transition: all 0.3s ease;
}

.drop-area:hover {
  background-color: #e6f0ff;
  transform: translateY(-2rpx);
}

.drop-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  background-color: #1677ff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.icon-text {
  font-size: 60rpx;
}

.drop-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 15rpx;
}

.drop-subtitle {
  font-size: 24rpx;
  color: #666666;
}

/* 文件信息卡片 */
.file-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  margin: 40rpx 0;
}

.file-info {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.file-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.file-details {
  flex: 1;
}

.file-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
  display: block;
}

.file-size {
  font-size: 24rpx;
  color: #666666;
}

.card-buttons {
  display: flex;
  justify-content: space-between;
}

.card-button {
  flex: 1;
  padding: 20rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  margin: 0 10rpx;
}

.card-button.primary {
  background-color: #1677ff;
  color: #ffffff;
}

.card-button.secondary {
  background-color: #f0f0f0;
  color: #333333;
  border: 1rpx solid #e5e5e5;
}

/* 课程分类选择页 */
.category-select {
  padding: 20rpx 0;
}

.preview-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.document-preview {
  background-color: #ffffff;
  border-radius: 10rpx;
  padding: 40rpx;
  min-height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #e5e5e5;
}

.preview-placeholder {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 20rpx;
}

.preview-button {
  background-color: #1677ff;
  color: #ffffff;
  padding: 15rpx 30rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  margin-top: 20rpx;
}

.category-section {
  margin-bottom: 40rpx;
}

.category-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.category-card {
  background-color: #ffffff;
  border-radius: 15rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #e5e5e5;
  transition: all 0.3s ease;
  cursor: pointer;
}

.category-card:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.category-card.selected {
  border-color: #1677ff;
  background-color: #f0f5ff;
}

.category-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.category-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.import-button {
  background-color: #1677ff;
  color: #ffffff;
  padding: 24rpx;
  border-radius: 10rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 40rpx;
  width: 100%;
}

.import-button:disabled {
  background-color: #cccccc;
  color: #ffffff;
}

/* 解析加载页 */
.loading-page {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 8rpx solid #f3f3f3;
  border-top: 8rpx solid #1677ff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 30rpx;
}

.page-animation {
  font-size: 28rpx;
  color: #666666;
}

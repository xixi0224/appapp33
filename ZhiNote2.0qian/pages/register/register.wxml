<view class="container">
  <view class="register-form">
    <view class="logo">
      <text>📚</text>
    </view>
    <view class="title">注册账号</view>
    <view class="subtitle">创建您的智能学习助手账号</view>
    
    <view class="form-group">
      <text class="label">用户名</text>
      <input class="input" placeholder="请输入用户名" bindinput="onUsernameInput" value="{{username}}" />
    </view>
    
    <view class="form-group">
      <text class="label">密码</text>
      <input class="input" type="password" placeholder="请输入密码（至少6位）" bindinput="onPasswordInput" value="{{password}}" />
    </view>
    
    <view class="form-group">
      <text class="label">确认密码</text>
      <input class="input" type="password" placeholder="请再次输入密码" bindinput="onConfirmPasswordInput" value="{{confirmPassword}}" />
    </view>
    
    <view class="form-group">
      <text class="label">邮箱（可选）</text>
      <input class="input" type="text" placeholder="请输入邮箱" bindinput="onEmailInput" value="{{email}}" />
    </view>
    
    <view class="form-group">
      <text class="label">手机号（可选）</text>
      <input class="input" type="text" placeholder="请输入手机号" bindinput="onPhoneInput" value="{{phone}}" />
    </view>
    
    <button class="register-btn" bindtap="register">注册</button>
    
    <view class="login-link">
      <text>已有账号？</text>
      <text class="login" bindtap="goLogin">立即登录</text>
    </view>
  </view>
</view>
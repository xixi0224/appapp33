page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.container {
  width: 100%;
  padding: 40rpx;
}

.login-form {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
  max-width: 500rpx;
  margin: 0 auto;
}

.logo {
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

.logo text {
  font-size: 100rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 10rpx;
  color: #333333;
}

.subtitle {
  font-size: 24rpx;
  text-align: center;
  margin-bottom: 50rpx;
  color: #666666;
}

.form-group {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  font-weight: 500;
  margin-bottom: 10rpx;
  color: #333333;
}

.input {
  width: 100%;
  padding: 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #333333;
}

.input:focus {
  border-color: #1677ff;
  outline: none;
}

.login-btn {
  width: 100%;
  height: 80rpx;
  background: #1677ff;
  color: #ffffff;
  border: none;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: bold;
  margin-top: 20rpx;
  margin-bottom: 30rpx;
}

.login-btn:hover {
  background: #409eff;
}

.other-options {
  display: flex;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.register, .forgot {
  font-size: 22rpx;
  color: #1677ff;
}

.divider {
  display: flex;
  align-items: center;
  margin: 30rpx 0;
}

.divider::before,
.divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: #e0e0e0;
}

.divider text {
  padding: 0 20rpx;
  font-size: 20rpx;
  color: #999999;
}

.third-party-login {
  display: flex;
  justify-content: space-around;
  margin-top: 30rpx;
}

.third-party-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
}

.third-party-item text:first-child {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.third-party-item text:last-child {
  font-size: 20rpx;
  color: #666666;
}
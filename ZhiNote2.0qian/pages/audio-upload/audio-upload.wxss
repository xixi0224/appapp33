.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  margin-bottom: 40rpx;
  text-align: center;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.upload-area {
  width: 100%;
  height: 400rpx;
  border: 2rpx dashed #ccc;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fff;
  cursor: pointer;
  transition: all 0.3s ease;
}

.upload-area:active {
  background-color: #f0f0f0;
}

.upload-icon {
  margin-bottom: 20rpx;
}

.icon {
  font-size: 80rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.upload-tip {
  font-size: 20rpx;
  color: #999;
}

.file-info {
  width: 100%;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.file-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.file-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.file-size {
  font-size: 24rpx;
  color: #999;
  margin-left: 20rpx;
}

.file-details {
  margin-bottom: 30rpx;
}

.file-duration {
  font-size: 24rpx;
  color: #666;
}

.file-actions {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-secondary {
  background-color: #f0f0f0;
  color: #333;
  margin-right: 20rpx;
}

.btn-primary {
  background-color: #1677ff;
  color: #fff;
}

.progress-container {
  margin-top: 20rpx;
}

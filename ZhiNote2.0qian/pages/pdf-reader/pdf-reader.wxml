<view class="container">
  <!-- PDF文件列表 -->
  <view wx:if="{{!currentPdf}}" class="pdf-list">
    <text class="list-title">我的PDF讲义</text>
    <view class="pdf-items">
      <view 
        wx:for="{{pdfList}}" 
        wx:key="id"
        class="pdf-item"
        bindtap="openPdf"
        data-id="{{item.id}}"
      >
        <view class="pdf-icon">📄</view>
        <view class="pdf-info">
          <text class="pdf-name">{{item.name}}</text>
          <text class="pdf-date">{{item.date}}</text>
        </view>
        <view class="pdf-arrow">→</view>
      </view>
      
      <view wx:if="{{pdfList.length === 0}}" class="empty-state">
        <text class="empty-text">暂无PDF文件</text>
      </view>
    </view>
  </view>
  
  <!-- PDF阅读界面 -->
  <view wx:else class="pdf-viewer">
    <view class="viewer-header">
      <button class="back-button" bindtap="closePdf">← 返回</button>
      <text class="pdf-title">{{currentPdf.name}}</text>
      <button class="tool-button" bindtap="showTools">工具</button>
    </view>
    
    <view class="viewer-content">
      <web-view src="{{currentPdf.url}}" wx:if="{{currentPdf.url}}"></web-view>
      <view wx:else class="placeholder">
        <text class="placeholder-text">PDF预览区域</text>
        <text class="placeholder-sub">支持画线、高亮、添加备注</text>
      </view>
    </view>
    
    <!-- 工具栏 -->
    <view wx:if="{{showToolPanel}}" class="tool-panel">
      <view class="tool-row">
        <button class="tool-item" bindtap="drawLine">画线</button>
        <button class="tool-item" bindtap="highlight">高亮</button>
        <button class="tool-item" bindtap="addNote">添加备注</button>
      </view>
    </view>
  </view>
</view>
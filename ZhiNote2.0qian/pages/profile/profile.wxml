<view class="container">
  <view class="profile-header">
    <view class="back-btn" bindtap="goBack">
      <text>←</text>
    </view>
    <text class="header-title">个人资料</text>
    <view class="save-btn" bindtap="saveProfile">
      <text>保存</text>
    </view>
  </view>
  
  <view class="profile-content">
    <!-- 头像 -->
    <view class="avatar-section">
      <view class="avatar" bindtap="chooseAvatar">
        <text>{{userInfo.avatar || '👤'}}</text>
      </view>
      <text class="change-avatar">更换头像</text>
    </view>
    
    <!-- 基本信息 -->
    <view class="info-section">
      <view class="info-item">
        <text class="info-label">用户名</text>
        <input class="info-input" value="{{userInfo.username}}" bindinput="onUsernameInput" />
      </view>
      
      <view class="info-item">
        <text class="info-label">昵称</text>
        <input class="info-input" value="{{userInfo.nickname || userInfo.username}}" bindinput="onNicknameInput" />
      </view>
      
      <view class="info-item">
        <text class="info-label">邮箱</text>
        <input class="info-input" placeholder="请输入邮箱" value="{{userInfo.email || ''}}" bindinput="onEmailInput" />
      </view>
      
      <view class="info-item">
        <text class="info-label">手机号</text>
        <input class="info-input" placeholder="请输入手机号" value="{{userInfo.phone || ''}}" bindinput="onPhoneInput" />
      </view>
    </view>
    
    <!-- 退出登录 -->
    <view class="logout-btn" bindtap="logout">
      <text>退出登录</text>
    </view>
  </view>
</view>
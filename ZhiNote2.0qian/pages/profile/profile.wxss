page {
  background: #f7f8fa;
  min-height: 100vh;
}

.container {
  width: 100%;
  min-height: 100vh;
}

.profile-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #ffffff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.save-btn {
  color: #1677ff;
  font-size: 28rpx;
  font-weight: 500;
}

.profile-content {
  padding: 40rpx 24rpx;
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #1677ff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  cursor: pointer;
}

.avatar text {
  font-size: 80rpx;
}

.change-avatar {
  font-size: 24rpx;
  color: #1677ff;
}

.info-section {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
  margin-bottom: 40rpx;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  width: 120rpx;
  font-size: 24rpx;
  color: #666;
}

.info-input {
  flex: 1;
  font-size: 24rpx;
  color: #333;
  padding: 10rpx 0;
}

.logout-btn {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
  color: #ff4d4f;
  font-size: 28rpx;
  font-weight: 500;
  cursor: pointer;
}

.logout-btn:active {
  background: #f0f0f0;
}
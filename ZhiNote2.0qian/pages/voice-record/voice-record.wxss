page {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  color: #ffffff;
  min-height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 20rpx 40rpx;
  min-height: 100vh;
}

.timer {
  margin-top: 60rpx;
}

.timer-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
}

.status {
  margin-top: 20rpx;
}

.status-text {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
}

.mic-container {
  position: relative;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 60rpx 0;
}

.mic-icon {
  width: 200rpx;
  height: 200rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  box-shadow: 0 0 40rpx rgba(255, 255, 255, 0.3);
}

.mic-emoji {
  font-size: 80rpx;
}

.wave-container {
  position: absolute;
  width: 300rpx;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.wave {
  position: absolute;
  width: 100%;
  height: 100%;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  animation: wave 2s infinite ease-out;
  opacity: 0;
}

@keyframes wave {
  0% {
    transform: scale(0.8);
    opacity: 1;
  }
  100% {
    transform: scale(1.5);
    opacity: 0;
  }
}

.bottom-buttons {
  display: flex;
  justify-content: space-around;
  width: 100%;
  margin-top: 40rpx;
}

.button {
  flex: 1;
  height: 100rpx;
  margin: 0 10rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.button.pause {
  background-color: rgba(255, 193, 7, 0.3);
  border: 2rpx solid rgba(255, 193, 7, 0.5);
}

.button.pause:disabled {
  background-color: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.3);
}

.button.resume {
  background-color: #1677ff;
  border: 2rpx solid #1677ff;
}

.button.resume:disabled {
  background-color: rgba(22, 119, 255, 0.3);
  border-color: rgba(22, 119, 255, 0.3);
  color: rgba(255, 255, 255, 0.3);
}

.button.record {
  background-color: #ff4d4f;
  border: 2rpx solid #ff4d4f;
}

.button.record:disabled {
  background-color: rgba(255, 77, 79, 0.3);
  border-color: rgba(255, 77, 79, 0.3);
  color: rgba(255, 255, 255, 0.3);
}

.button.play {
  background-color: #52c41a;
  border: 2rpx solid #52c41a;
}

.button.restart {
  background-color: rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.button-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
}

.button.pause:disabled .button-text,
.button.resume:disabled .button-text {
  color: rgba(255, 255, 255, 0.3);
}

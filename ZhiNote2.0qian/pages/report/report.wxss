page {
  background: #f7f8fa;
  color: #1f1f1f;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
  position: relative;
}

.share-icon {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 60rpx;
  height: 60rpx;
  background-color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  z-index: 10;
}

.share-icon text {
  font-size: 30rpx;
}

.overview {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.overview-item {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  text-align: center;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
  margin-right: 10rpx;
}

.overview-item:last-child {
  margin-right: 0;
}

.overview-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #1677ff;
  margin-bottom: 5rpx;
  display: block;
}

.overview-label {
  font-size: 20rpx;
  color: #666;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.chart-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
  height: 400rpx;
}

ec-canvas {
  width: 100%;
  height: 100%;
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: #999;
}

.empty-text {
  font-size: 24rpx;
  text-align: center;
}

/* 学习记录卡片 */
.record-cards {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.record-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
  text-align: center;
  position: relative;
  overflow: hidden;
  cursor: pointer;
  transition: transform 0.3s ease;
}

.record-card:active {
  transform: scale(0.98);
}

.record-icon {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  font-size: 40rpx;
  opacity: 0.1;
}

.time-icon {
  color: #1677ff;
}

.note-icon {
  color: #52c41a;
}

.review-icon {
  color: #fa8c16;
}

.record-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}

.record-label {
  font-size: 24rpx;
  color: #666;
}

/* 图表切换标签 */
.chart-tabs {
  display: flex;
  margin-bottom: 20rpx;
  background-color: #f0f0f0;
  border-radius: 10rpx;
  padding: 4rpx;
}

.chart-tab {
  flex: 1;
  text-align: center;
  padding: 15rpx;
  border-radius: 8rpx;
  transition: all 0.3s ease;
  cursor: pointer;
}

.chart-tab.active {
  background-color: #1677ff;
  color: #ffffff;
}

.chart-tab text {
  font-size: 28rpx;
  font-weight: 500;
}

/* 全套可视化 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.export-btn {
  background-color: #1677ff;
  color: #ffffff;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  cursor: pointer;
}

.chart-matrix {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.chart-cell {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
}

.chart-title {
  font-size: 24rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
  color: #333;
  text-align: center;
}

.chart-container {
  height: 300rpx;
}

.chart-container ec-canvas {
  width: 100%;
  height: 100%;
}
<view class="container">
  <!-- 单词卡片 -->
  <view class="card-container">
    <view 
      class="word-card {{isFlipped ? 'flipped' : ''}}"
      bindtap="flipCard"
    >
      <view class="card-front">
        <text class="word-text">{{currentWord.english}}</text>
        <text class="word-hint">点击查看释义</text>
      </view>
      <view class="card-back">
        <text class="word-translation">{{currentWord.chinese}}</text>
        <text class="word-phonetic">{{currentWord.phonetic}}</text>
      </view>
    </view>
  </view>
  
  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button class="action-button unknown" bindtap="markUnknown">
      <text class="button-icon">✗</text>
      <text class="button-text">不认识</text>
    </button>
    <button class="action-button known" bindtap="markKnown">
      <text class="button-icon">✓</text>
      <text class="button-text">认识</text>
    </button>
  </view>
  
  <!-- 进度显示 -->
  <view class="progress-section">
    <text class="progress-text">{{currentIndex + 1}} / {{wordList.length}}</text>
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{(currentIndex + 1) / wordList.length * 100}}%"></view>
    </view>
  </view>
  
  <!-- 统计信息 -->
  <view class="stats-section">
    <view class="stat-item">
      <text class="stat-value">{{knownCount}}</text>
      <text class="stat-label">已认识</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{unknownCount}}</text>
      <text class="stat-label">需复习</text>
    </view>
  </view>
</view>
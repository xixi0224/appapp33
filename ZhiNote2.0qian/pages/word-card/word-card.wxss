page {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  min-height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  min-height: 100vh;
}

/* 单词卡片 */
.card-container {
  width: 100%;
  height: 400rpx;
  perspective: 1000rpx;
  margin-bottom: 60rpx;
}

.word-card {
  width: 100%;
  height: 100%;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.6s;
  border-radius: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
}

.word-card.flipped {
  transform: rotateY(180deg);
}

.card-front,
.card-back {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx;
}

.card-front {
  z-index: 2;
}

.card-back {
  transform: rotateY(180deg);
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.word-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.word-hint {
  font-size: 24rpx;
  color: #999999;
}

.word-translation {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 15rpx;
}

.word-phonetic {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 30rpx;
  margin-bottom: 60rpx;
}

.action-button {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  border: none;
  font-size: 24rpx;
}

.action-button.unknown {
  background-color: rgba(255, 255, 255, 0.3);
  color: #ffffff;
}

.action-button.known {
  background-color: #ffffff;
  color: #f5576c;
}

.button-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.button-text {
  font-size: 24rpx;
  font-weight: bold;
}

/* 进度显示 */
.progress-section {
  width: 100%;
  margin-bottom: 40rpx;
}

.progress-text {
  font-size: 28rpx;
  color: #ffffff;
  margin-bottom: 10rpx;
  display: block;
  text-align: center;
}

.progress-bar {
  width: 100%;
  height: 10rpx;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #ffffff;
  transition: width 0.3s ease;
}

/* 统计信息 */
.stats-section {
  display: flex;
  gap: 60rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

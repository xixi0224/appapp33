page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

.player-container {
  background-color: #ffffff;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.player {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.play-button {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #1677ff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.play-icon {
  font-size: 32rpx;
  color: #ffffff;
}

.progress-container {
  flex: 1;
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.time {
  font-size: 20rpx;
  color: #666666;
  margin: 0 10rpx;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background-color: #e5e5e5;
  border-radius: 4rpx;
  overflow: hidden;
  position: relative;
}

.progress-fill {
  height: 100%;
  background-color: #1677ff;
  border-radius: 4rpx;
}

.speed-control {
  position: relative;
}

.speed-text {
  font-size: 24rpx;
  color: #1677ff;
  padding: 8rpx 16rpx;
  border: 1rpx solid #1677ff;
  border-radius: 16rpx;
}

.speed-options {
  position: absolute;
  top: 100%;
  right: 0;
  background-color: #ffffff;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
  margin-top: 8rpx;
}

.speed-option {
  padding: 12rpx 20rpx;
  min-width: 80rpx;
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.speed-option:last-child {
  border-bottom: none;
}

.speed-option-text {
  font-size: 24rpx;
  color: #333333;
}

.transcript-container {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.transcript {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.transcript-item {
  margin-bottom: 20rpx;
  display: flex;
  align-items: flex-start;
}

.timestamp {
  font-size: 20rpx;
  color: #1677ff;
  margin-right: 16rpx;
  min-width: 100rpx;
  font-weight: bold;
  cursor: pointer;
}

.text {
  flex: 1;
  font-size: 24rpx;
  color: #333333;
  line-height: 40rpx;
}

.save-button-container {
  padding: 20rpx;
  background-color: #ffffff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.save-button {
  width: 100%;
  height: 80rpx;
  background-color: #1677ff;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 40rpx;
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 20rpx;
  color: #999;
  min-height: 300rpx;
}

.empty-text {
  font-size: 24rpx;
  text-align: center;
}

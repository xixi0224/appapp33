page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.container {
  padding: 20rpx;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 15rpx;
  display: block;
}

.setting-list {
  background-color: #ffffff;
  border-radius: 10rpx;
  overflow: hidden;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 28rpx;
  color: #333333;
}

.setting-value {
  font-size: 24rpx;
  color: #999999;
}

.setting-switch {
  transform: scale(0.8);
}

/* 间隔重复设置 */
.interval-settings {
  background-color: #f9f9f9;
  padding: 20rpx;
  margin: 10rpx 0;
  border-radius: 8rpx;
}

.interval-title {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 15rpx;
  display: block;
}

.interval-list {
  display: flex;
  flex-direction: column;
}

.interval-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #e5e5e5;
}

.interval-item:last-child {
  border-bottom: none;
}

.interval-label {
  font-size: 24rpx;
  color: #666666;
}

.interval-switch {
  transform: scale(0.7);
}

/* 深色模式 */
page.dark {
  background-color: #1a1a1a;
}

.dark .section-title {
  color: #666666;
}

.dark .setting-list {
  background-color: #2d2d2d;
}

.dark .setting-item {
  border-bottom: 1rpx solid #3d3d3d;
}

.dark .setting-label {
  color: #ffffff;
}

.dark .setting-value {
  color: #999999;
}

.dark .interval-settings {
  background-color: #252525;
}

.dark .interval-title {
  color: #999999;
}

.dark .interval-item {
  border-bottom: 1rpx solid #3d3d3d;
}

.dark .interval-label {
  color: #cccccc;
}

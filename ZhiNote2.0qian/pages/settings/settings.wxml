<view class="container">
  <!-- 系统设置 -->
  <view class="section">
    <text class="section-title">系统设置</text>
    <view class="setting-list">
      <view class="setting-item">
        <text class="setting-label">深色模式</text>
        <switch class="setting-switch" checked="{{darkMode}}" bindchange="onDarkModeChange" />
      </view>
      <view class="setting-item">
        <text class="setting-label">字体大小</text>
        <view class="setting-value">标准</view>
      </view>
    </view>
  </view>
  
  <!-- 学习设置 -->
  <view class="section">
    <text class="section-title">学习设置</text>
    <view class="setting-list">
      <view class="setting-item">
        <text class="setting-label">复习提醒</text>
        <switch class="setting-switch" checked="{{reviewReminder}}" bindchange="onReviewReminderChange" />
      </view>
      
      <!-- 间隔重复设置 -->
      <view wx:if="{{reviewReminder}}" class="interval-settings">
        <text class="interval-title">间隔重复设置</text>
        <view class="interval-list">
          <view class="interval-item">
            <text class="interval-label">第1天</text>
            <switch class="interval-switch" checked="{{interval1}}" bindchange="onInterval1Change" />
          </view>
          <view class="interval-item">
            <text class="interval-label">第3天</text>
            <switch class="interval-switch" checked="{{interval3}}" bindchange="onInterval3Change" />
          </view>
          <view class="interval-item">
            <text class="interval-label">第7天</text>
            <switch class="interval-switch" checked="{{interval7}}" bindchange="onInterval7Change" />
          </view>
          <view class="interval-item">
            <text class="interval-label">第15天</text>
            <switch class="interval-switch" checked="{{interval15}}" bindchange="onInterval15Change" />
          </view>
        </view>
      </view>
      
      <view class="setting-item">
        <text class="setting-label">学习计划提醒</text>
        <switch class="setting-switch" checked="{{planReminder}}" bindchange="onPlanReminderChange" />
      </view>
    </view>
  </view>
  
  <!-- 通知设置 -->
  <view class="section">
    <text class="section-title">通知设置</text>
    <view class="setting-list">
      <view class="setting-item">
        <text class="setting-label">允许通知</text>
        <switch class="setting-switch" checked="{{notificationEnabled}}" bindchange="onNotificationChange" />
      </view>
      <view class="setting-item">
        <text class="setting-label">通知时间段</text>
        <view class="setting-value">09:00 - 21:00</view>
      </view>
    </view>
  </view>
  
  <!-- 其他 -->
  <view class="section">
    <text class="section-title">其他</text>
    <view class="setting-list">
      <view class="setting-item" bindtap="goCache">
        <text class="setting-label">清除缓存</text>
        <view class="setting-value">0 MB</view>
      </view>
      <view class="setting-item" bindtap="goVersion">
        <text class="setting-label">版本信息</text>
        <view class="setting-value">v1.0.0</view>
      </view>
    </view>
  </view>
</view>
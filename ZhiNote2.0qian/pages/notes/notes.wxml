<view class="container">
  <!-- 笔记列表模式 -->
  <block wx:if="{{isListMode}}">
    <view class="page-title">我的笔记</view>
    
    <!-- 加载状态 -->
    <block wx:if="{{loading}}">
      <view class="loading-state">
        <text class="loading-text">加载中...</text>
      </view>
    </block>
    
    <!-- 笔记列表 -->
    <block wx:elif="{{allNotes.length > 0}}">
      <view class="note-card" wx:for="{{allNotes}}" wx:key="id" bindtap="goNoteDetail" data-id="{{item.id}}" data-title="{{item.title}}" bindlongpress="showRenameModal" data-note-id="{{item.id}}" data-note-title="{{item.title}}">
        <view class="note-title">{{item.title}}</view>
        <view class="note-info">
          <text class="note-source">{{item.source}}</text>
          <text class="note-date">{{item.date}}</text>
        </view>
        <view class="note-tags">
          <view class="note-tag {{tagItem.className}}" wx:for="{{item.tags}}" wx:key="tagIndex" wx:for-item="tagItem">{{tagItem.name}}</view>
        </view>
      </view>
    </block>
    
    <!-- 空状态 -->
    <block wx:else>
      <view class="empty-state">
        <text class="empty-text">暂无笔记</text>
      </view>
    </block>
  </block>
  
  <!-- 单个笔记详情模式 -->
  <block wx:else>
    <!-- 分享图标 -->
    <view class="share-icon" bindtap="showSharePanel">
      <text>📤</text>
    </view>
    
    <!-- 魔法棒图标 -->
    <view class="magic-icon" bindtap="showMagicOptions">
      <text>🪄</text>
    </view>
    
    <view class="card">
      <view class="title">结构化笔记</view>
      <view class="sub">文档ID：{{doc_id}}</view>
    </view>

    <view class="card" wx:for="{{notes}}" wx:key="index">
      <view class="title" style="font-size: 32rpx;">{{item.section}}</view>
      <view style="margin-bottom: 12rpx;">{{item.summary}}</view>
      <view>
        <text class="tag" wx:for="{{item.keywords}}" wx:key="*this">{{item}}</text>
      </view>
      <view style="margin-top: 10rpx;">考点：{{item.is_exam_point ? '是' : '否'}} | 重要度：{{item.importance}}</view>
    </view>

    <view class="card" wx:if="{{!notes.length}}">
      <view class="sub">暂无数据，请先完成上传和分析。</view>
    </view>

    <view class="card">
      <button class="btn-primary" bindtap="goChart">查看图表</button>
    </view>
  </block>
  
  <!-- 分享面板 -->
  <share-panel 
    show="{{showSharePanel}}" 
    page-type="notes" 
    page-data="{{pageData}}" 
    bind:close="closeSharePanel"
  />
  
  <!-- 魔法选项弹窗 -->
  <view class="magic-modal" wx:if="{{showMagicModal}}">
    <view class="modal-mask" bindtap="closeMagicModal"></view>
    <view class="modal-content">
      <view class="modal-title">AI魔法功能</view>
      <view class="modal-options">
        <view class="modal-option" bindtap="generateCompleteNote">
          <view class="option-icon">📝</view>
          <view class="option-text">生成完整笔记</view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="cancel-button" bindtap="closeMagicModal">取消</button>
      </view>
    </view>
  </view>
  
  <!-- 重命名弹窗 -->
  <view class="magic-modal" wx:if="{{showRenameModal}}">
    <view class="modal-mask" bindtap="closeRenameModal"></view>
    <view class="modal-content">
      <view class="modal-title">修改笔记名称</view>
      <view class="rename-input-wrapper">
        <input 
          class="rename-input" 
          value="{{renameValue}}" 
          bindinput="onRenameInput"
          placeholder="请输入新的笔记名称"
          maxlength="50"
          focus="{{showRenameModal}}"
        />
      </view>
      <view class="modal-footer">
        <button class="cancel-button" bindtap="closeRenameModal">取消</button>
        <button class="confirm-button" bindtap="confirmRename">确定</button>
      </view>
    </view>
  </view>
</view>
page {
  background: #f7f8fa;
  color: #1f1f1f;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
  position: relative;
}

.share-icon {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 60rpx;
  height: 60rpx;
  background-color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  z-index: 10;
}

.share-icon text {
  font-size: 30rpx;
}

.magic-icon {
  position: absolute;
  top: 24rpx;
  right: 100rpx;
  width: 60rpx;
  height: 60rpx;
  background-color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  z-index: 10;
}

.magic-icon text {
  font-size: 30rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.sub {
  color: #666;
  font-size: 24rpx;
}

.btn-primary {
  background: #1677ff;
  color: #fff;
  border-radius: 16rpx;
}

.btn-ghost {
  background: #eef4ff;
  color: #1677ff;
  border-radius: 16rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #f0f5ff;
  color: #1677ff;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

/* 魔法选项弹窗 */
.magic-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1000;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  background-color: #fff;
  border-top-left-radius: 30rpx;
  border-top-right-radius: 30rpx;
  padding: 30rpx 24rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
  color: #333;
}

.modal-options {
  margin-bottom: 30rpx;
}

.modal-option {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #f7f8fa;
  border-radius: 15rpx;
  margin-bottom: 15rpx;
  cursor: pointer;
}

.modal-option:active {
  background-color: #e8e8e8;
}

.option-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.option-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.modal-footer {
  display: flex;
  justify-content: center;
}

.cancel-button {
  width: 100%;
  padding: 20rpx;
  background-color: #f0f0f0;
  color: #333;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.cancel-button:active {
  background-color: #e0e0e0;
}

/* 笔记列表模式样式 */
.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  text-align: center;
}

.note-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
  cursor: pointer;
  transition: background-color 0.2s;
}

.note-card:hover {
  background-color: #fafafa;
}

.note-card:active {
  background-color: #f0f0f0;
}

.note-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.note-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.note-source {
  font-size: 20rpx;
  color: #1677ff;
  background-color: #e6f7ff;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.note-date {
  font-size: 20rpx;
  color: #999;
}

.note-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.note-tag {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.note-tag.tag-exam {
  background-color: #fff2e8;
  color: #ff4d4f;
}

.note-tag.tag-important {
  background-color: #f9f0ff;
  color: #722ed1;
}

.note-tag.tag-difficult {
  background-color: #ffe7e7;
  color: #eb2f96;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 20rpx;
  color: #999;
}

.loading-text {
  font-size: 24rpx;
  text-align: center;
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 20rpx;
  color: #999;
}

.empty-text {
  font-size: 24rpx;
  text-align: center;
}

/* 重命名弹窗样式 */
.rename-input-wrapper {
  padding: 30rpx;
  background-color: #f7f8fa;
  border-radius: 12rpx;
  margin: 20rpx 0;
}

.rename-input {
  width: 100%;
  padding: 20rpx;
  background-color: #ffffff;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.rename-input:focus {
  border-color: #667eea;
}

.confirm-button {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 30rpx;
  margin-left: 20rpx;
  flex: 1;
}

.modal-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 30rpx;
}

.cancel-button {
  background-color: #f7f8fa;
  color: #666666;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 30rpx;
  flex: 1;
  margin-right: 20rpx;
}
<view class="container">
  <!-- 笔记信息 -->
  <view class="note-info" wx:if="{{fileInfo}}">
    <text class="note-title">{{fileInfo.name}}</text>
    <text class="note-source">来自：{{fileInfo.source}}</text>
  </view>
  
  <!-- 分析功能卡片 -->
  <scroll-view class="actions-scroll" scroll-y="true">
    <view class="analysis-actions">
      <view class="action-card {{fileInfo.category === 'audio' ? 'expanded' : ''}}" bindtap="goAsr">
        <view class="action-left">
          <view class="action-icon asr"></view>
        </view>
        <view class="action-middle">
          <text class="action-title">语音转文字</text>
          <text class="action-desc">将音频转换为文字，支持分段标记</text>
        </view>
        <view class="action-right">
          <button class="start-button" wx:if="{{fileInfo.category !== 'audio'}}">开始分析</button>
        </view>
      </view>
      
      <view class="action-card {{showClassSummary ? 'expanded' : ''}}" bindtap="goClassSummary">
        <view class="action-left">
          <view class="action-icon summary"></view>
        </view>
        <view class="action-middle">
          <text class="action-title">AI课堂总结</text>
          <text class="action-desc">AI 生成课程大纲、章节摘要、重点整理和难点分析</text>
        </view>
        <view class="action-right">
          <button class="start-button" wx:if="{{!isAnalyzing && !showClassSummary}}">开始分析</button>
          <view class="analyzing" wx:if="{{isAnalyzing}}">
            <view class="brain-animation"></view>
            <text>思考中…</text>
          </view>
        </view>
      </view>
      
      <!-- 课堂总结展开内容 -->
      <view class="class-summary-content" wx:if="{{showClassSummary}}">
        <view class="summary-header">
          <text class="summary-title">AI课堂总结</text>
          <button class="generate-image-button" bindtap="generateSummaryImage" wx:if="{{!showSummaryImage}}">生成摘要图</button>
        </view>
        
        <!-- 摘要图显示区域 -->
        <view class="summary-image-container" wx:if="{{showSummaryImage}}">
          <image src="{{summaryImageUrl}}" mode="widthFix" class="summary-image"></image>
          <view class="summary-image-actions">
            <button class="action-button save-button" bindtap="saveSummaryImage">保存到相册</button>
            <button class="action-button share-button" open-type="share">分享给朋友</button>
          </view>
        </view>
        
        <view class="tab-container">
          <view class="tab-header">
            <view 
              class="tab-item {{activeTab === 'outline' ? 'active' : ''}}" 
              bindtap="switchTab" 
              data-tab="outline"
            >
              课程大纲
            </view>
            <view 
              class="tab-item {{activeTab === 'summary' ? 'active' : ''}}" 
              bindtap="switchTab" 
              data-tab="summary"
            >
              每章摘要
            </view>
            <view 
              class="tab-item {{activeTab === 'keypoints' ? 'active' : ''}}" 
              bindtap="switchTab" 
              data-tab="keypoints"
            >
              重点整理
            </view>
            <view 
              class="tab-item {{activeTab === 'difficulties' ? 'active' : ''}}" 
              bindtap="switchTab" 
              data-tab="difficulties"
            >
              难点分析
            </view>
          </view>
          
          <view class="tab-content">
            <!-- 课程大纲 -->
            <view class="tab-pane" wx:if="{{activeTab === 'outline'}}">
              <view class="outline-list">
                <view class="outline-item level-1" wx:for="{{classSummary.outline}}" wx:key="id">
                  <text class="outline-text">{{item.title}}</text>
                  <view class="outline-item level-2" wx:for="{{item.subtopics}}" wx:key="id" wx:for-item="subtopic">
                    <text class="outline-text">{{subtopic.title}}</text>
                  </view>
                </view>
              </view>
            </view>
            
            <!-- 每章摘要 -->
            <view class="tab-pane" wx:if="{{activeTab === 'summary'}}">
              <view class="summary-list">
                <view class="summary-item" wx:for="{{classSummary.chapterSummaries}}" wx:key="id">
                  <text class="summary-chapter">{{item.chapter}}</text>
                  <text class="summary-content">{{item.summary}}</text>
                </view>
              </view>
            </view>
            
            <!-- 重点整理 -->
            <view class="tab-pane" wx:if="{{activeTab === 'keypoints'}}">
              <view class="keypoints-list">
                <view class="keypoint-item" wx:for="{{classSummary.keypoints}}" wx:key="id">
                  <text class="keypoint-text">{{item.text}}</text>
                </view>
              </view>
            </view>
            
            <!-- 难点分析 -->
            <view class="tab-pane" wx:if="{{activeTab === 'difficulties'}}">
              <view class="difficulties-list">
                <view class="difficulty-item" wx:for="{{classSummary.difficulties}}" wx:key="id">
                  <text class="difficulty-title">{{item.title}}</text>
                  <text class="difficulty-explanation">{{item.explanation}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
      
      <view class="action-card exam-card {{showExamPoints ? 'expanded' : ''}}" bindtap="goExamPoints">
        <view class="action-left">
          <view class="action-icon exam"></view>
        </view>
        <view class="action-middle">
          <text class="action-title">考点识别</text>
          <text class="action-desc">识别高频考点，标记重要度和易考标记</text>
        </view>
        <view class="action-right">
          <button class="start-button" wx:if="{{!isExtractingExamPoints && !showExamPoints}}">开始分析</button>
          <view class="analyzing" wx:if="{{isExtractingExamPoints}}">
            <view class="brain-animation"></view>
            <text>分析中…</text>
          </view>
        </view>
      </view>
      
      <!-- 考点识别展开内容 -->
      <view class="exam-points-content" wx:if="{{showExamPoints}}">
        <view class="exam-header">
          <text class="exam-title">考点识别</text>
        </view>
        
        <scroll-view scroll-x="true" class="exam-table-scroll" scroll-left="{{tableScrollLeft}}" enhanced="true" show-scrollbar="true">
          <view class="exam-table-inner">
            <view class="table-header" style="min-width: 900rpx;">
              <view class="table-cell name">考点名称</view>
              <view class="table-cell importance">重要程度</view>
              <view class="table-cell question-types">易考题型</view>
              <view class="table-cell location">出现位置</view>
            </view>
            
            <view class="table-body">
              <view
                class="table-row {{point.isMastered ? 'mastered' : ''}} {{pointIndex === expandedRowIndex ? 'expanded' : ''}}"
                wx:for="{{examPoints}}"
                wx:for-item="point"
                wx:for-index="pointIndex"
                wx:key="id"
                bindtap="toggleRowActions"
                data-index="{{pointIndex}}"
                style="min-width: 900rpx;"
              >
                <view class="row-content">
                  <view class="table-cell name">
                    <text>{{point.name}}</text>
                    <text class="mastered-icon" wx:if="{{point.isMastered}}">✅</text>
                  </view>
                  <view class="table-cell importance">
                    <view class="stars">
                      <text class="star {{starIndex < point.importance ? 'active' : ''}}" wx:for="[1,2,3,4,5]" wx:for-item="star" wx:for-index="starIndex" wx:key="*this">⭐</text>
                    </view>
                  </view>
                  <view class="table-cell question-types">
                    <view class="tag" wx:for="{{point.questionTypes}}" wx:for-item="qt" wx:for-index="qtIndex" wx:key="*this">{{qt}}</view>
                  </view>
                  <view class="table-cell location">
                    <text>{{point.location}}</text>
                  </view>
                </view>

                <!-- 左滑操作按钮 -->
                <view class="row-actions">
                  <view class="action-btn add-to-plan" catchtap="addToReviewPlan" data-index="{{pointIndex}}">加入复习计划</view>
                  <view class="action-btn mark-mastered" catchtap="markAsMastered" data-index="{{pointIndex}}">{{point.isMastered ? '取消掌握' : '标记为已掌握'}}</view>
                </view>
              </view>
            </view>
          </view>
        </scroll-view>
      </view>
      
      <view class="action-card {{showContentCompress ? 'expanded' : ''}}" bindtap="goContentCompress">
        <view class="action-left">
          <view class="action-icon compress"></view>
        </view>
        <view class="action-middle">
          <text class="action-title">内容压缩</text>
          <text class="action-desc">长讲义转换为一页精简笔记，智能分段重组</text>
        </view>
        <view class="action-right">
          <button class="start-button" wx:if="{{!isCompressing && !showContentCompress}}">开始分析</button>
          <view class="analyzing" wx:if="{{isCompressing}}">
            <view class="brain-animation"></view>
            <text>压缩中…</text>
          </view>
        </view>
      </view>
      
      <!-- 内容压缩展开内容 -->
      <view class="content-compress-content" wx:if="{{showContentCompress && !isComparing}}">
        <view class="compress-header">
          <text class="compress-title">一页纸精华笔记</text>
        </view>
        
        <!-- A4纸视图 -->
        <view class="a4-paper">
          <view class="paper-content">
            <text class="paper-title">{{compressedContent.title}}</text>
            <view class="paper-body">
              <view class="paper-section" wx:for="{{compressedContent.sections}}" wx:key="index">
                    <text class="section-title">{{item.title}}</text>
                    <view class="section-content">
                      <view class="bullet-point" wx:for="{{item.points}}" wx:key="pointIndex">
                        <text class="bullet">•</text>
                        <text class="point-text">{{item}}</text>
                      </view>
                    </view>
                  </view>
            </view>
          </view>
        </view>
        
        <!-- 操作按钮 -->
        <view class="compress-actions">
          <button class="action-button save-button" bindtap="saveCompressedVersion">保存此版本</button>
          <button class="action-button compare-button" bindtap="compareWithOriginal">对比原版</button>
        </view>
      </view>
      
      <!-- 对比原版模式 -->
      <view class="compare-content" wx:if="{{isComparing}}">
        <view class="compare-header">
          <text class="compare-title">原文与压缩版对比</text>
          <button class="back-button" bindtap="exitCompareMode">返回</button>
        </view>
        
        <view class="compare-layout">
          <!-- 左侧原文 -->
          <view class="original-content">
            <text class="content-title">原文</text>
            <scroll-view class="content-scroll" scroll-y="true">
              <view class="original-text">
                {{originalContent}}
              </view>
            </scroll-view>
          </view>
          
          <!-- 右侧压缩版 -->
          <view class="compressed-content">
            <text class="content-title">压缩版</text>
            <scroll-view class="content-scroll" scroll-y="true">
              <view class="a4-paper small">
                <view class="paper-content">
                  <text class="paper-title">{{compressedContent.title}}</text>
                  <view class="paper-body">
                    <view class="paper-section" wx:for="{{compressedContent.sections}}" wx:key="index">
                      <text class="section-title">{{item.title}}</text>
                      <view class="section-content">
                        <view class="bullet-point" wx:for="{{item.points}}" wx:key="pointIndex">
                          <text class="bullet">•</text>
                          <text class="point-text">{{item}}</text>
                        </view>
                      </view>
                    </view>
                  </view>
                </view>
              </view>
            </scroll-view>
          </view>
        </view>
      </view>
      
      <view class="action-card {{showKnowledgeExtract ? 'expanded' : ''}}" bindtap="goKnowledgeExtract">
        <view class="action-left">
          <view class="action-icon extract"></view>
        </view>
        <view class="action-middle">
          <text class="action-title">知识点提取</text>
          <text class="action-desc">从内容中提取核心知识点，构建知识体系</text>
        </view>
        <view class="action-right">
          <button class="start-button" wx:if="{{!isExtracting && !showKnowledgeExtract}}">开始分析</button>
          <view class="analyzing" wx:if="{{isExtracting}}">
            <view class="brain-animation"></view>
            <text>提取中…</text>
          </view>
        </view>
      </view>
      
      <!-- 知识点提取展开内容 -->
      <view class="knowledge-extract-content" wx:if="{{showKnowledgeExtract}}">
        <view class="extract-header">
          <text class="extract-title">知识点提取</text>
        </view>
        
        <view class="extract-layout">
          <!-- 左侧知识点列表 -->
          <view class="knowledge-list-container">
            <view class="filter-bar">
              <text class="filter-label">按章节筛选：</text>
              <picker mode="selector" range="{{chapters}}" bindchange="onChapterChange" value="{{selectedChapterIndex}}">
                <view class="filter-picker">
                  {{chapters[selectedChapterIndex] || '全部章节'}}
                </view>
              </picker>
            </view>
            
            <scroll-view class="knowledge-list" scroll-y="true">
              <view 
                class="knowledge-item {{selectedKnowledgeIndex === index ? 'selected' : ''}}" 
                wx:for="{{filteredKnowledge}}" 
                wx:key="id"
                bindtap="selectKnowledge"
                data-index="{{index}}"
              >
                <text class="knowledge-title">{{item.title}}</text>
                <view class="knowledge-actions">
                  <view class="add-to-library" bindtap="addKnowledgeToLibrary" data-index="{{index}}">
                    <text>+</text>
                  </view>
                </view>
              </view>
            </scroll-view>
          </view>
          
          <!-- 右侧详情和关键词云 -->
          <view class="knowledge-detail-container">
            <!-- 关键词云 -->
            <view class="keyword-cloud">
              <text class="cloud-title">关键词云</text>
              <ec-canvas id="keywordCloud" canvas-id="keywordCloudCanvas" ec="{{ec}}" style="width: 100%; height: 200rpx;"></ec-canvas>
            </view>
            
            <!-- 知识点详情 -->
            <view class="knowledge-detail" wx:if="{{selectedKnowledge}}">
              <text class="detail-title">{{selectedKnowledge.title}}</text>
              <text class="detail-content">{{selectedKnowledge.detail}}</text>
            </view>
            <view class="knowledge-detail empty" wx:else>
              <text>请选择一个知识点查看详情</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
  
  <!-- 语音转文字展开内容 -->
  <view class="asr-content" wx:if="{{showAsrContent}}">
    <view class="asr-header">
      <text class="asr-title">语音转文字</text>
      <view class="close-button" bindtap="hideAsrContent">
        <text>✕</text>
      </view>
    </view>
    <scroll-view class="transcript-scroll" scroll-y="true">
      <view class="transcript-list">
        <view 
          class="transcript-item {{item.hasTags ? 'highlighted' : ''}}" 
          wx:for="{{transcript}}" 
          wx:key="index"
          bindtap="selectSegment"
          data-index="{{index}}"
        >
          <view class="segment-header">
            <text class="segment-time">{{item.time}}</text>
            <view class="tag-icon" bindtap="showTagMenu" data-index="{{index}}">
              <text>🏷️</text>
            </view>
          </view>
          <text class="segment-text">{{item.text}}</text>
          <view class="segment-tags" wx:if="{{item.tags && item.tags.length > 0}}">
            <view class="tag {{tag === '重点' ? 'keypoint' : (tag === '难点' ? 'difficulty' : 'exam')}}" wx:for="{{item.tags}}" wx:key="*this">
              <text wx:if="{{tag === '重点'}}">重点</text>
              <text wx:if="{{tag === '难点'}}">难点</text>
              <text wx:if="{{tag === '考点'}}">考点</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
  
  <!-- 标签选择菜单 -->
  <view class="tag-menu" wx:if="{{showTagMenu}}">
    <view class="tag-menu-mask" bindtap="hideTagMenu"></view>
    <view class="tag-menu-content">
      <text class="menu-title">选择标签</text>
      <view class="menu-options">
        <view class="menu-option" bindtap="addTag" data-tag="重点">
          <view class="option-icon keypoint"></view>
          <text>重点</text>
        </view>
        <view class="menu-option" bindtap="addTag" data-tag="难点">
          <view class="option-icon difficulty"></view>
          <text>难点</text>
        </view>
        <view class="menu-option" bindtap="addTag" data-tag="考点">
          <view class="option-icon exam"></view>
          <text>考点</text>
        </view>
      </view>
    </view>
  </view>
</view>
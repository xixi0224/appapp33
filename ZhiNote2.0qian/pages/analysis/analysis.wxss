page {
  background: #f7f8fa;
  color: #1f1f1f;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
}

/* 笔记信息 */
.note-info {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
}

.note-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.note-source {
  font-size: 24rpx;
  color: #1677ff;
  display: block;
}

/* 分析功能卡片 */
.actions-scroll {
  height: calc(100vh - 200rpx);
}

.analysis-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
  display: flex;
  align-items: center;
  transition: transform 0.2s;
}

/* 考点识别卡片样式 */
.action-card.exam-card {
  border: 4rpx solid #ff4d4f;
  box-shadow: 0 0 30rpx rgba(255, 77, 79, 0.2);
  background: linear-gradient(135deg, #fff5f5 0%, #fff1f0 100%);
}

.action-card:active {
  transform: scale(0.98);
}

.action-card.expanded {
  background: linear-gradient(135deg, #e6f7ff 0%, #bae7ff 100%);
}

.action-left {
  margin-right: 20rpx;
}

.action-middle {
  flex: 1;
}

.action-right {
  margin-left: 20rpx;
}

.start-button {
  padding: 12rpx 24rpx;
  background-color: #1677ff;
  color: #fff;
  font-size: 24rpx;
  border: none;
  border-radius: 12rpx;
}

.start-button:active {
  background-color: #0958d9;
}

/* 语音转文字展开内容 */
.asr-content {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #fff;
  z-index: 100;
  display: flex;
  flex-direction: column;
}

.asr-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.asr-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.close-button {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #999;
}

.transcript-scroll {
  flex: 1;
  padding: 24rpx;
}

.transcript-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.transcript-item {
  background-color: #f7f8fa;
  border-radius: 15rpx;
  padding: 20rpx;
  transition: background-color 0.3s;
}

.transcript-item.highlighted {
  background-color: #fff7e6;
}

.segment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.segment-time {
  font-size: 22rpx;
  color: #1677ff;
  font-weight: bold;
}

.tag-icon {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.segment-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  display: block;
  margin-bottom: 15rpx;
}

.segment-tags {
  display: flex;
  gap: 10rpx;
}

.segment-tags .tag {
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
}

.segment-tags .tag.keypoint {
  background-color: #ff7875;
  color: #fff;
}

.segment-tags .tag.difficulty {
  background-color: #fa8c16;
  color: #fff;
}

.segment-tags .tag.exam {
  background-color: #52c41a;
  color: #fff;
}

/* 标签选择菜单 */
.tag-menu {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
}

.tag-menu-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.tag-menu-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 20rpx 20rpx 0 0;
  padding: 30rpx;
  animation: slideUp 0.3s ease;
}

.menu-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 30rpx;
  text-align: center;
}

.menu-options {
  display: flex;
  gap: 20rpx;
}

.menu-option {
  flex: 1;
  background-color: #f7f8fa;
  border-radius: 15rpx;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: transform 0.2s;
}

.menu-option:active {
  transform: scale(0.95);
}

.option-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.option-icon.keypoint {
  background-color: #ff7875;
  color: #fff;
}

.option-icon.difficulty {
  background-color: #fa8c16;
  color: #fff;
}

.option-icon.exam {
  background-color: #52c41a;
  color: #fff;
}

.menu-option text {
  font-size: 24rpx;
  color: #333;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

/* 分析中状态 */
.analyzing {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #1677ff;
  font-size: 24rpx;
}

.brain-animation {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid #1677ff;
  border-radius: 50%;
  border-top-color: transparent;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 课堂总结展开内容 */
.class-summary-content {
  background: #fff;
  border-radius: 20rpx;
  margin-top: 20rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
}

.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.summary-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.generate-image-button {
  padding: 12rpx 24rpx;
  background-color: #1677ff;
  color: #fff;
  font-size: 24rpx;
  border: none;
  border-radius: 12rpx;
}

.generate-image-button:active {
  background-color: #0958d9;
}

/* 摘要图显示区域 */
.summary-image-container {
  margin-top: 30rpx;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background-color: #f7f8fa;
  border-radius: 15rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-image {
  width: 100%;
  max-width: 600rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.summary-image-actions {
  display: flex;
  gap: 20rpx;
  width: 100%;
  max-width: 600rpx;
}

.share-button {
  background-color: #52c41a;
  color: #fff;
}

.share-button:active {
  background-color: #389e0d;
}

/* 标签页 */
.tab-container {
  margin-top: 20rpx;
}

.tab-header {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: #666;
  position: relative;
  transition: color 0.3s;
}

.tab-item.active {
  color: #1677ff;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 10%;
  width: 80%;
  height: 4rpx;
  background-color: #1677ff;
  border-radius: 2rpx;
}

.tab-content {
  min-height: 400rpx;
}

.tab-pane {
  padding: 10rpx 0;
}

/* 课程大纲 */
.outline-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.outline-item {
  padding: 15rpx 0;
}

.outline-item.level-1 {
  border-left: 4rpx solid #1677ff;
  padding-left: 20rpx;
}

.outline-item.level-2 {
  border-left: 2rpx solid #e0e0e0;
  padding-left: 40rpx;
  margin-top: 10rpx;
}

.outline-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}

/* 每章摘要 */
.summary-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.summary-item {
  background-color: #f7f8fa;
  border-radius: 15rpx;
  padding: 20rpx;
}

.summary-chapter {
  font-size: 28rpx;
  font-weight: bold;
  color: #1677ff;
  display: block;
  margin-bottom: 10rpx;
}

.summary-content {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  display: block;
}

/* 重点整理 */
.keypoints-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.keypoint-item {
  background-color: #fff7e6;
  border-radius: 15rpx;
  padding: 20rpx;
  border-left: 4rpx solid #fa8c16;
}

.keypoint-text {
  font-size: 24rpx;
  color: #333;
  line-height: 1.6;
  display: block;
  font-weight: bold;
}

/* 难点分析 */
.difficulties-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.difficulty-item {
  background-color: #f0f0f0;
  border-radius: 15rpx;
  padding: 20rpx;
}

.difficulty-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.difficulty-explanation {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  display: block;
  font-style: italic;
}

/* 深色模式 */
.dark .note-info {
  background-color: #2d2d2d;
}

.dark .note-title {
  color: #fff;
}

.dark .action-card {
  background-color: #2d2d2d;
}

.dark .action-title {
  color: #fff;
}

.dark .action-desc {
  color: #cccccc;
}

.dark .asr-content {
  background-color: #2d2d2d;
}

.dark .asr-header {
  border-bottom-color: #3d3d3d;
}

.dark .asr-title {
  color: #fff;
}

.dark .transcript-item {
  background-color: #3d3d3d;
}

.dark .transcript-item.highlighted {
  background-color: #4d3d2d;
}

.dark .segment-text {
  color: #cccccc;
}

.dark .tag-menu-content {
  background-color: #2d2d2d;
}

.dark .menu-title {
  color: #fff;
}

.dark .menu-option {
  background-color: #3d3d3d;
}

.dark .menu-option text {
  color: #cccccc;
}

.dark .class-summary-content {
  background-color: #2d2d2d;
}

.dark .summary-title {
  color: #fff;
}

.dark .tab-header {
  border-bottom-color: #3d3d3d;
}

.dark .tab-item {
  color: #cccccc;
}

.dark .outline-text {
  color: #cccccc;
}

.dark .summary-item {
  background-color: #3d3d3d;
}

.dark .summary-content {
  color: #cccccc;
}

.dark .keypoint-item {
  background-color: #4d3d2d;
}

.dark .keypoint-text {
  color: #cccccc;
}

.dark .difficulty-item {
  background-color: #3d3d3d;
}

.dark .difficulty-title {
  color: #cccccc;
}

.dark .difficulty-explanation {
  color: #cccccc;
}

/* 知识点提取展开内容 */
.knowledge-extract-content {
  background: #fff;
  border-radius: 20rpx;
  margin-top: 20rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
}

.extract-header {
  margin-bottom: 30rpx;
}

.extract-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.extract-layout {
  display: flex;
  gap: 24rpx;
  min-height: 500rpx;
}

/* 左侧知识点列表 */
.knowledge-list-container {
  flex: 1;
  min-width: 300rpx;
}

.filter-bar {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-label {
  font-size: 24rpx;
  color: #666;
  margin-right: 15rpx;
}

.filter-picker {
  flex: 1;
  font-size: 24rpx;
  color: #1677ff;
  padding: 10rpx 15rpx;
  background-color: #f0f9ff;
  border-radius: 10rpx;
  text-align: center;
}

.knowledge-list {
  height: 400rpx;
  border-radius: 15rpx;
  overflow: hidden;
}

.knowledge-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #f7f8fa;
  border-radius: 15rpx;
  margin-bottom: 15rpx;
  transition: all 0.3s;
}

.knowledge-item:hover {
  background-color: #e6f7ff;
}

.knowledge-item.selected {
  background-color: #e6f7ff;
  border-left: 4rpx solid #1677ff;
}

.knowledge-title {
  font-size: 24rpx;
  color: #333;
  flex: 1;
  margin-right: 15rpx;
  line-height: 1.4;
}

.knowledge-actions {
  display: flex;
  align-items: center;
}

.add-to-library {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: #1677ff;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  transition: all 0.3s;
}

.add-to-library:hover {
  background-color: #0958d9;
  transform: scale(1.1);
}

/* 右侧详情和关键词云 */
.knowledge-detail-container {
  flex: 2;
  min-width: 400rpx;
}

.keyword-cloud {
  background-color: #f7f8fa;
  border-radius: 15rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.cloud-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.cloud-container {
  height: 200rpx;
  width: 100%;
  position: relative;
}

/* 知识点详情 */
.knowledge-detail {
  background-color: #f7f8fa;
  border-radius: 15rpx;
  padding: 24rpx;
  min-height: 250rpx;
}

.knowledge-detail.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 24rpx;
}

.detail-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1677ff;
  margin-bottom: 15rpx;
  display: block;
}

.detail-content {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  display: block;
}

/* 深色模式 */
.dark .knowledge-extract-content {
  background-color: #2d2d2d;
}

.dark .extract-title {
  color: #fff;
}

.dark .filter-label {
  color: #cccccc;
}

.dark .filter-picker {
  color: #1677ff;
  background-color: #1a2e44;
}

.dark .knowledge-item {
  background-color: #3d3d3d;
}

.dark .knowledge-item:hover {
  background-color: #1a2e44;
}

.dark .knowledge-item.selected {
  background-color: #1a2e44;
}

.dark .knowledge-title {
  color: #cccccc;
}

.dark .keyword-cloud {
  background-color: #3d3d3d;
}

.dark .cloud-title {
  color: #fff;
}

.dark .knowledge-detail {
  background-color: #3d3d3d;
}

.dark .knowledge-detail.empty {
  color: #666;
}

.dark .detail-title {
  color: #1677ff;
}

.dark .detail-content {
  color: #cccccc;
}

/* 内容压缩展开内容 */
.content-compress-content {
  background: #fff;
  border-radius: 20rpx;
  margin-top: 20rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
}

.compress-header {
  margin-bottom: 30rpx;
}

.compress-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* A4纸视图 */
.a4-paper {
  width: 100%;
  background-color: #fff9e6;
  border-radius: 10rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
  padding: 40rpx;
  margin-bottom: 30rpx;
  background-image: linear-gradient(#fff9e6 1px, transparent 1px);
  background-size: 100% 30rpx;
  background-position: 0 20rpx;
}

.a4-paper.small {
  padding: 20rpx;
  margin-bottom: 0;
}

.paper-content {
  position: relative;
  z-index: 1;
}

.paper-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
  display: block;
}

.paper-body {
  font-size: 24rpx;
  line-height: 1.6;
  color: #333;
}

.paper-section {
  margin-bottom: 25rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1677ff;
  margin-bottom: 15rpx;
  display: block;
}

.section-content {
  margin-left: 30rpx;
}

.bullet-point {
  display: flex;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.bullet {
  color: #1677ff;
  font-weight: bold;
  margin-right: 10rpx;
  line-height: 1.6;
}

.point-text {
  flex: 1;
  line-height: 1.6;
  color: #333;
}

/* 操作按钮 */
.compress-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.action-button {
  flex: 1;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: bold;
  border: none;
}

.save-button {
  background-color: #1677ff;
  color: #fff;
}

.save-button:active {
  background-color: #0958d9;
}

.compare-button {
  background-color: #52c41a;
  color: #fff;
}

.compare-button:active {
  background-color: #389e0d;
}

/* 对比原版模式 */
.compare-content {
  background: #fff;
  border-radius: 20rpx;
  margin-top: 20rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
}

.compare-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.compare-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.back-button {
  padding: 12rpx 24rpx;
  background-color: #f0f0f0;
  color: #333;
  font-size: 24rpx;
  border: none;
  border-radius: 12rpx;
}

.back-button:active {
  background-color: #e0e0e0;
}

.compare-layout {
  display: flex;
  gap: 24rpx;
  min-height: 500rpx;
}

.original-content,
.compressed-content {
  flex: 1;
  min-width: 300rpx;
}

.content-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  display: block;
}

.content-scroll {
  height: 500rpx;
  border-radius: 15rpx;
  overflow: hidden;
  border: 1rpx solid #f0f0f0;
}

.original-text {
  padding: 20rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #333;
}

/* 深色模式 */
.dark .content-compress-content,
.dark .compare-content {
  background-color: #2d2d2d;
}

.dark .compress-title,
.dark .compare-title {
  color: #fff;
}

.dark .a4-paper {
  background-color: #3d3d3d;
  background-image: linear-gradient(#3d3d3d 1px, transparent 1px);
}

.dark .paper-title {
  color: #fff;
}

.dark .paper-body {
  color: #cccccc;
}

.dark .section-title {
  color: #1677ff;
}

.dark .point-text {
  color: #cccccc;
}

.dark .back-button {
  background-color: #3d3d3d;
  color: #cccccc;
}

.dark .content-title {
  color: #fff;
}

.dark .content-scroll {
  border-color: #3d3d3d;
}

.dark .original-text {
  color: #cccccc;
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.action-icon.asr {
  background-color: #e6f7ff;
  color: #1677ff;
}

.action-icon.summary {
  background-color: #e6f7ff;
  color: #1677ff;
}

.action-icon.exam {
  background-color: #f6ffed;
  color: #52c41a;
}

.action-icon.compress {
  background-color: #fff2e8;
  color: #fa8c16;
}

.action-icon.extract {
  background-color: #f9f0ff;
  color: #722ed1;
}

/* 考点识别卡片样式 */
.exam-card {
  border: 2rpx solid #ff4d4f;
  background-color: #fff2f0;
}

.exam-card.expanded {
  background: linear-gradient(135deg, #fff2f0 0%, #ffccc7 100%);
}

.action-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}

/* 考点识别展开内容 */
.exam-points-content {
  background: #fff;
  border-radius: 20rpx;
  margin-top: 20rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
}

.exam-header {
  margin-bottom: 30rpx;
}

.exam-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 考点表格 */
.exam-table-scroll {
  width: 100%;
  border-radius: 15rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  white-space: nowrap;
}

.exam-table-inner {
  display: inline-block;
  min-width: 100%;
}

.table-header {
  display: flex;
  background-color: #ff4d4f;
  color: #fff;
  font-weight: bold;
  font-size: 24rpx;
}

.table-cell {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.table-cell.name {
  flex: 2;
  text-align: left;
}

.table-cell.importance {
  flex: 1;
}

.table-cell.question-types {
  flex: 1.5;
}

.table-cell.location {
  flex: 1.5;
}

.table-body {
  background-color: #fff;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
  transition: background-color 0.3s;
  overflow: hidden;
}

.table-row:last-child {
  border-bottom: none;
}

.table-row:hover {
  background-color: #f7f8fa;
}

/* 行内容容器，用于左滑动画 */
.row-content {
  display: flex;
  flex: 1;
  transition: transform 0.3s ease;
}

.table-row.expanded .row-content {
  transform: translateX(-240rpx);
}

/* 已掌握状态：灰色 */
.table-row.mastered {
  background-color: #f5f5f5;
}

.table-row.mastered .table-cell {
  color: #999;
}

/* 重要程度星星 */
.stars {
  display: flex;
  justify-content: center;
  gap: 5rpx;
}

.star {
  font-size: 24rpx;
  color: #d9d9d9;
  transition: color 0.3s;
}

.star.active {
  color: #faad14;
}

/* 易考题型标签 */
.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  background-color: #e6f7ff;
  color: #1677ff;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

/* 左滑操作按钮 */
.row-actions {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  z-index: 10;
  transform: translateX(100%);
  transition: transform 0.3s ease;
}

.table-row.expanded .row-actions {
  transform: translateX(0);
}

.action-btn {
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  border: none;
  color: #fff;
}

.add-to-plan {
  background-color: #1677ff;
}

.mark-mastered {
  background-color: #52c41a;
}

/* 已掌握图标 */
.mastered-icon {
  margin-left: 10rpx;
  font-size: 20rpx;
}

/* 深色模式 */
.dark .exam-card {
  border-color: #ff7875;
  background-color: #2d1f1f;
}

.dark .exam-card.expanded {
  background: linear-gradient(135deg, #2d1f1f 0%, #3d2f2f 100%);
}

.dark .exam-points-content {
  background-color: #2d2d2d;
}

.dark .exam-title {
  color: #fff;
}

.dark .table-header {
  background-color: #ff7875;
}

.dark .table-body {
  background-color: #2d2d2d;
}

.dark .table-row {
  border-bottom-color: #3d3d3d;
}

.dark .table-row:hover {
  background-color: #3d3d3d;
}

.dark .table-row.mastered {
  background-color: #3d3d3d;
}

.dark .table-row.mastered .table-cell {
  color: #888;
}

.dark .table-cell {
  color: #cccccc;
}

.dark .tag {
  background-color: #1a2e44;
  color: #1677ff;
}

.action-desc {
  font-size: 20rpx;
  color: #666;
  line-height: 1.4;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.record-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
}

.record-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.record-info {
  flex: 1;
}

.record-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 5rpx;
  display: block;
}

.record-type {
  font-size: 20rpx;
  color: #1677ff;
  margin-bottom: 5rpx;
  display: block;
}

.record-time {
  font-size: 20rpx;
  color: #999;
  display: block;
}

.record-arrow {
  width: 20rpx;
  height: 20rpx;
  border-top: 2rpx solid #999;
  border-right: 2rpx solid #999;
  transform: rotate(45deg);
}

/* 图标样式 */
.asr::before {
  content: "🎤";
}

.summary::before {
  content: "📝";
}

.exam::before {
  content: "🎯";
}

.compress::before {
  content: "📄";
}

.extract::before {
  content: "🔍";
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 20rpx;
  color: #999;
}

.empty-text {
  font-size: 24rpx;
  text-align: center;
}
page {
  background: #f7f8fa;
  color: #1f1f1f;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
}

.section {
  margin-bottom: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #1677ff;
}

.notes-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
}

.note-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.note-item:last-child {
  border-bottom: none;
}

.note-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.note-icon.math {
  background-color: #e6f7ff;
  color: #1677ff;
}

.note-icon.ds {
  background-color: #f6ffed;
  color: #52c41a;
}

.note-icon.english {
  background-color: #fff2e8;
  color: #fa8c16;
}

.note-info {
  flex: 1;
}

.note-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 5rpx;
  display: block;
}

.note-subtitle {
  font-size: 20rpx;
  color: #1677ff;
  margin-bottom: 5rpx;
  display: block;
}

.note-time {
  font-size: 20rpx;
  color: #999;
  display: block;
}

.note-arrow {
  width: 20rpx;
  height: 20rpx;
  border-top: 2rpx solid #999;
  border-right: 2rpx solid #999;
  transform: rotate(45deg);
}

.graph-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
  cursor: pointer;
}

.graph-card:active {
  background-color: #f5f5f5;
}

.graph-preview {
  width: 100%;
  height: 200rpx;
  background-color: #f0f0f0;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.graph-animation {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  opacity: 0.5;
}

.graph-node {
  position: absolute;
  border-radius: 50%;
  background-color: #d9d9d9;
  box-shadow: 0 0 5rpx rgba(0, 0, 0, 0.3);
}

.graph-node.center {
  width: 20rpx;
  height: 20rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: #1677ff;
}

.graph-node.node-1 {
  width: 12rpx;
  height: 12rpx;
  top: 20%;
  left: 50%;
  transform: translateX(-50%);
  background-color: #52c41a;
}

.graph-node.node-2 {
  width: 12rpx;
  height: 12rpx;
  top: 50%;
  right: 20%;
  transform: translateY(-50%);
  background-color: #fa8c16;
}

.graph-node.node-3 {
  width: 12rpx;
  height: 12rpx;
  bottom: 20%;
  left: 50%;
  transform: translateX(-50%);
  background-color: #ff4d4f;
}

.graph-node.node-4 {
  width: 12rpx;
  height: 12rpx;
  top: 50%;
  left: 20%;
  transform: translateY(-50%);
  background-color: #722ed1;
}

.graph-line {
  position: absolute;
  background-color: rgba(0, 0, 0, 0.1);
  transform-origin: center;
}

.graph-line.line-1 {
  width: 100rpx;
  height: 1rpx;
  top: 50%;
  left: 25rpx;
}

.graph-line.line-2 {
  width: 100rpx;
  height: 1rpx;
  top: 50%;
  left: 25rpx;
  transform: rotate(90deg);
}

.graph-desc {
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

/* 知识图谱真实数据预览 */
.graph-preview-real {
  width: 100%;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
  padding: 20rpx;
}

.graph-node-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
}

.graph-node-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 20rpx;
  background-color: #fff;
  border-radius: 16rpx;
  border: 2rpx solid #e8e8e8;
  min-width: 120rpx;
  max-width: 200rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.graph-node-item.theme-node {
  border-width: 3rpx;
  transform: scale(1.05);
}

.graph-node-item.exam-node {
  background-color: #fff5f5;
}

.node-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-bottom: 8rpx;
}

.node-name {
  font-size: 22rpx;
  color: #333;
  font-weight: 500;
  text-align: center;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.node-tag {
  font-size: 18rpx;
  margin-top: 6rpx;
  font-weight: 500;
}

.graph-stats {
  text-align: center;
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #e8e8e8;
}

.stats-text {
  font-size: 20rpx;
  color: #999;
}

.plan-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
  cursor: pointer;
}

.plan-card:active {
  background-color: #f5f5f5;
}

.plan-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.plan-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.plan-days {
  font-size: 22rpx;
  color: #1677ff;
}

.plan-progress {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.progress-label {
  font-size: 22rpx;
  color: #666;
  margin-right: 15rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background-color: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-value {
  font-size: 22rpx;
  font-weight: bold;
  color: #667eea;
  margin-left: 15rpx;
}

.today-tasks {
  margin-top: 15rpx;
}

.tasks-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  display: block;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.task-item {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background-color: #f7f8fa;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.task-check {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 3rpx solid #d9d9d9;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.task-check.checked {
  background-color: #52c41a;
  border-color: #52c41a;
}

.task-item.completed {
  opacity: 0.6;
}

.task-item.completed .task-text {
  text-decoration: line-through;
  color: #999;
}

.task-empty {
  padding: 30rpx 20rpx;
  text-align: center;
}

.task-empty-text {
  font-size: 24rpx;
  color: #bbb;
}

.task-text {
  font-size: 22rpx;
  color: #333;
  flex: 1;
  margin-left: 12rpx;
}

.empty-hint {
  font-size: 20rpx;
  color: #999;
  display: block;
  margin-top: 10rpx;
}

.plan-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.plan-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.plan-progress {
  font-size: 24rpx;
  color: #1677ff;
}

.plan-progress-bar {
  width: 100%;
  height: 10rpx;
  background-color: #f0f0f0;
  border-radius: 5rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.plan-progress-fill {
  height: 100%;
  background-color: #1677ff;
  border-radius: 5rpx;
}

.plan-tasks {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.plan-task {
  display: flex;
  align-items: center;
}

.task-checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 50%;
  margin-right: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.task-checkbox.checked {
  background-color: #1677ff;
  border-color: #1677ff;
}

.task-checkbox.checked::after {
  content: "✓";
  color: #fff;
  font-size: 20rpx;
  font-weight: bold;
}

.task-text {
  font-size: 24rpx;
  color: #333;
  flex: 1;
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 20rpx;
  color: #999;
}

.empty-text {
  font-size: 24rpx;
  text-align: center;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 20rpx;
  color: #999;
}

.loading-text {
  font-size: 24rpx;
  text-align: center;
}

/* 标签筛选 */
.tag-filter {
  display: flex;
  gap: 15rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.tag-filter-item {
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  background-color: #f0f0f0;
  color: #666;
  font-size: 24rpx;
  cursor: pointer;
}

.tag-filter-item.active {
  background-color: #1677ff;
  color: #fff;
}

/* 笔记卡片 */
.note-card {
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.note-card:last-child {
  border-bottom: none;
}

.note-card .note-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}

.note-card .note-info {
  display: flex;
  gap: 20rpx;
  margin-bottom: 10rpx;
}

.note-source {
  font-size: 22rpx;
  color: #999;
}

.note-date {
  font-size: 22rpx;
  color: #999;
}

.note-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.note-tag {
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
}

.note-tag.data-structure {
  background-color: #e6f7ff;
  color: #1677ff;
}

.note-tag.algorithm {
  background-color: #f6ffed;
  color: #52c41a;
}

.note-tag.tree {
  background-color: #fff7e6;
  color: #fa8c16;
}

.note-tag.tag-exam {
  background-color: #fff2e8;
  color: #ff4d4f;
}

.note-tag.tag-important {
  background-color: #f9f0ff;
  color: #722ed1;
}

.note-tag.tag-difficult {
  background-color: #ffe7e7;
  color: #eb2f96;
}

/* 图标样式 */
.math::before {
  content: "📐";
}

.ds::before {
  content: "📊";
}

.english::before {
  content: "📚";
}
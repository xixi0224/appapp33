<view class="container">
  <view class="forgot-password-form">
    <view class="logo">
      <text>🔐</text>
    </view>
    <view class="title">忘记密码</view>
    <view class="subtitle">通过邮箱重置您的密码</view>
    
    <!-- 步骤1：输入邮箱 -->
    <view class="form-group" wx:if="{{step === 1}}">
      <text class="label">注册邮箱</text>
      <input class="input" type="text" placeholder="请输入注册时的邮箱" bindinput="onEmailInput" value="{{email}}" />
      <button class="submit-btn" bindtap="requestReset">发送重置链接</button>
    </view>
    
    <!-- 步骤2：输入令牌和新密码 -->
    <view class="form-group" wx:if="{{step === 2}}">
      <view class="info-box">
        <text class="info-text">重置令牌已生成（开发环境）：</text>
        <text class="token-text">{{resetToken}}</text>
      </view>
      
      <text class="label">重置令牌</text>
      <input class="input" type="text" placeholder="请输入重置令牌" bindinput="onTokenInput" value="{{token}}" />
      
      <text class="label">新密码</text>
      <input class="input" type="password" placeholder="请输入新密码（至少6位）" bindinput="onNewPasswordInput" value="{{newPassword}}" />
      
      <text class="label">确认新密码</text>
      <input class="input" type="password" placeholder="请再次输入新密码" bindinput="onConfirmPasswordInput" value="{{confirmPassword}}" />
      
      <button class="submit-btn" bindtap="confirmReset">重置密码</button>
    </view>
    
    <view class="login-link">
      <text>想起密码了？</text>
      <text class="login" bindtap="goLogin">返回登录</text>
    </view>
  </view>
</view>

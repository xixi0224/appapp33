page {
  background: #f7f8fa;
  color: #1f1f1f;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
  position: relative;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding-top: 20rpx;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  margin-right: 20rpx;
}

.nav-back text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.nav-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.chart-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
  height: 400rpx;
}

ec-canvas {
  width: 100%;
  height: 100%;
}

.record-list {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04);
  min-height: 300rpx;
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  min-height: 200rpx;
  color: #999;
}

.empty-text {
  font-size: 24rpx;
  text-align: center;
}
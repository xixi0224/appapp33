<view class="container">
  <!-- 分享图标 -->
  <view class="share-icon" bindtap="showSharePanel">
    <text>📤</text>
  </view>
  
  <!-- 搜索框和操作按钮 -->
  <view class="search-container">
    <view class="search-box">
      <input
        class="search-input"
        placeholder="搜索知识点..."
        bindinput="onSearchInput"
        value="{{searchKeyword}}"
      />
      <view class="search-icon" bindtap="clearSearch">
        <text wx:if="{{searchKeyword}}">✕</text>
      </view>
    </view>
    <view class="regenerate-btn" bindtap="generateGlobalGraph">
      <text>重新生成</text>
    </view>
  </view>

  <!-- 单笔记选择器 -->
  <view class="note-selector" wx:if="{{noteList.length > 0}}">
    <picker mode="selector" range="{{noteList}}" range-key="title" value="{{selectedNoteIndex}}" bindchange="onNoteSelect">
      <view class="note-picker">
        <text class="note-picker-label">{{graphMode === 'global' ? '全局图谱' : '笔记：'}}{{noteList[selectedNoteIndex].title}}</text>
        <text class="note-picker-arrow">▼</text>
      </view>
    </picker>
    <view class="note-generate-btn" bindtap="generateNoteGraph">
      <text>为该笔记生成</text>
    </view>
  </view>

  <!-- 知识图谱画布 -->
  <view class="chart-wrapper {{panelOpen ? 'chart-hidden' : ''}}">
    <ec-canvas id="mychart-dom-bar" canvas-id="mychart-bar" ec="{{ ec }}" class="chart-canvas"></ec-canvas>
    <view class="empty-tip" wx:if="{{!hasData && !isLoading}}">
      <text class="empty-icon">📊</text>
      <text class="empty-title">暂无知识图谱数据</text>
      <text class="empty-desc">点击上方「重新生成」创建全局图谱</text>
      <text class="empty-desc" wx:if="{{noteList.length > 0}}">或选择笔记后点击「为该笔记生成」</text>
    </view>
    <view class="loading-tip" wx:if="{{isLoading}}">
      <text class="loading-text">加载中...</text>
    </view>
  </view>
  
  <!-- 详情面板 -->
  <view class="detail-panel {{showDetailPanel ? 'show' : ''}}">
    <view class="panel-mask" bindtap="closeDetailPanel"></view>
    <view class="panel-content">
      <view class="panel-header">
        <text class="panel-title">{{selectedNode.name}}</text>
        <view class="header-buttons">
          <view class="play-demo-button" bindtap="showDemoCanvas" wx:if="{{isDemoAvailable}}">
            <text>播放演示</text>
          </view>
          <view class="close-button" bindtap="closeDetailPanel">
            <text>✕</text>
          </view>
        </view>
      </view>
      <view class="panel-body">
        <view class="panel-section">
          <text class="section-label">定义</text>
          <text class="section-content">{{selectedNode.definition}}</text>
        </view>
        <view class="panel-section">
          <text class="section-label">关联笔记</text>
          <view class="notes-list">
            <view class="note-item" wx:for="{{selectedNode.relatedNotes}}" wx:key="index" bindtap="goToNoteDetail" data-id="{{item.id}}" data-title="{{item.title}}">
              <text class="note-title">{{item.title}}</text>
              <text class="note-date">{{item.date}}</text>
            </view>
            <view class="note-empty" wx:if="{{selectedNode.relatedNotes.length === 0}}">
              <text class="note-empty-text">暂无关联笔记</text>
            </view>
          </view>
        </view>
        <view class="panel-section">
          <text class="section-label">掌握程度</text>
          <view class="mastery-level">
            <view class="mastery-bar">
              <view class="mastery-fill" style="width: {{selectedNode.mastery}}%"></view>
            </view>
            <text class="mastery-text">{{selectedNode.mastery}}%</text>
          </view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 动态演示画布 -->
  <view class="demo-canvas {{showDemoCanvas ? 'show' : ''}}">
    <view class="canvas-mask" bindtap="closeDemoCanvas"></view>
    <view class="canvas-container">
      <view class="canvas-header">
        <text class="canvas-title">{{selectedNode.name}} 动态演示</text>
        <view class="close-button" bindtap="closeDemoCanvas">
          <text>✕</text>
        </view>
      </view>
      <canvas canvas-id="demoCanvas" class="demo-canvas-element"></canvas>
      <view class="canvas-controls">
        <view class="control-button" bindtap="prevStep">
          <text>上一步</text>
        </view>
        <view class="control-button" bindtap="togglePlay">
          <text>{{isPlaying ? '暂停' : '播放'}}</text>
        </view>
        <view class="control-button" bindtap="nextStep">
          <text>下一步</text>
        </view>
      </view>
      <view class="demo-description">
        <text class="description-text">{{demoDescription}}</text>
      </view>
    </view>
  </view>
  
  <!-- 添加节点浮动按钮 -->
  <view class="fab-button" bindtap="showAddNodePanel">
    <text class="fab-icon">+</text>
  </view>

  <!-- 添加节点面板 -->
  <view class="add-node-panel {{showAddNodePanel ? 'show' : ''}}">
    <view class="panel-mask" bindtap="closeAddNodePanel"></view>
    <view class="add-node-content">
      <view class="add-node-header">
        <text class="add-node-title">添加知识点</text>
        <view class="close-button" bindtap="closeAddNodePanel">
          <text>✕</text>
        </view>
      </view>
      <view class="add-node-body">
        <view class="form-item">
          <text class="form-label">节点名称</text>
          <input class="form-input" placeholder="输入知识点名称" value="{{newNodeName}}" bindinput="onNodeNameInput" />
        </view>
        <view class="form-item">
          <text class="form-label">节点类型</text>
          <picker mode="selector" range="{{nodeTypes}}" range-key="label" value="{{newNodeTypeIndex}}" bindchange="onNodeTypeChange">
            <view class="form-picker">{{nodeTypes[newNodeTypeIndex].label}}</view>
          </picker>
        </view>
        <view class="form-item">
          <text class="form-label">定义描述</text>
          <textarea class="form-textarea" placeholder="输入知识点的定义（可选）" value="{{newNodeDefinition}}" bindinput="onNodeDefinitionInput" />
        </view>
        <view class="form-actions">
          <view class="form-btn cancel" bindtap="closeAddNodePanel">取消</view>
          <view class="form-btn confirm" bindtap="submitAddNode">确认添加</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 分享面板 -->
  <share-panel 
    show="{{showSharePanel}}" 
    page-type="chart" 
    page-data="{{pageData}}" 
    chart-data="{{chartData}}" 
    bind:close="closeSharePanel"
  />
</view>
page {
  background: #1a1a1a;
  color: #ffffff;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
  position: relative;
}

.share-icon {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 60rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  z-index: 10;
  cursor: pointer;
}

.share-icon:active {
  background-color: rgba(255, 255, 255, 0.2);
}

/* 搜索框样式 */
.search-container {
  margin-bottom: 20rpx;
  position: relative;
  z-index: 5;
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.search-box {
  display: flex;
  align-items: center;
  flex: 1;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 30rpx;
  padding: 15rpx 20rpx;
}

.regenerate-btn {
  padding: 15rpx 24rpx;
  background-color: #1677ff;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #ffffff;
  white-space: nowrap;
  cursor: pointer;
}

.regenerate-btn:active {
  background-color: #409eff;
}

.search-input {
  flex: 1;
  color: #ffffff;
  font-size: 28rpx;
  placeholder-color: rgba(255, 255, 255, 0.5);
}

.search-icon {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.search-icon text {
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
}

/* 单笔记选择器 */
.note-selector {
  display: flex;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 20rpx;
  z-index: 5;
}

.note-picker {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  color: #ffffff;
  font-size: 26rpx;
}

.note-picker-label {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 70%;
}

.note-picker-arrow {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

.note-generate-btn {
  padding: 18rpx 24rpx;
  background-color: #52c41a;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #ffffff;
  white-space: nowrap;
  cursor: pointer;
}

.note-generate-btn:active {
  background-color: #73d13d;
}

/* 知识图谱画布 */
.chart-wrapper {
  position: relative;
  width: 100%;
  height: calc(100vh - 320rpx);
  background-color: #1a1a1a;
  border-radius: 12rpx;
  overflow: hidden;
  transition: opacity 0.2s ease;
}

.chart-wrapper.chart-hidden {
  position: fixed;
  left: -9999px;
  top: -9999px;
  opacity: 0;
  pointer-events: none;
}

.ec-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

.empty-tip {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  z-index: 2;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: bold;
}

.empty-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.loading-tip {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.loading-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 详情面板 */
.detail-panel {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 999;
  display: flex;
  justify-content: flex-end;
  pointer-events: none;
}

.detail-panel.show {
  pointer-events: auto;
}

.panel-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  opacity: 0;
  transition: opacity 0.3s ease;
  z-index: 999;
}

.detail-panel.show .panel-mask {
  opacity: 1;
}

.panel-content {
  position: relative;
  width: 80%;
  height: 100%;
  background-color: #2a2a2a;
  transform: translateX(100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
  z-index: 1000;
}

.detail-panel.show .panel-content {
  transform: translateX(0);
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.header-buttons {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.play-demo-button {
  padding: 10rpx 20rpx;
  background-color: #1677ff;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #ffffff;
  cursor: pointer;
}

.play-demo-button:active {
  background-color: #409eff;
}

.panel-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.close-button {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.close-button text {
  color: #ffffff;
  font-size: 24rpx;
}

.panel-body {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
}

.panel-section {
  margin-bottom: 30rpx;
}

.section-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 10rpx;
}

.section-content {
  font-size: 26rpx;
  color: #ffffff;
  line-height: 1.5;
}

.notes-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.note-item {
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  padding: 15rpx;
}

.note-title {
  font-size: 24rpx;
  color: #ffffff;
  margin-bottom: 5rpx;
  display: block;
}

.note-date {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  display: block;
}

.mastery-level {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.mastery-bar {
  flex: 1;
  height: 10rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 5rpx;
  overflow: hidden;
}

.mastery-fill {
  height: 100%;
  background-color: #1677ff;
  border-radius: 5rpx;
  transition: width 0.3s ease;
}

.mastery-text {
  font-size: 24rpx;
  color: #1677ff;
  font-weight: bold;
  min-width: 60rpx;
  text-align: right;
}

/* 动态演示画布 */
.demo-canvas {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.demo-canvas.show {
  pointer-events: auto;
}

.canvas-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.8);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.demo-canvas.show .canvas-mask {
  opacity: 1;
}

.canvas-container {
  width: 90%;
  max-width: 600rpx;
  background-color: #1a1a1a;
  border-radius: 20rpx;
  overflow: hidden;
  transform: scale(0.8);
  opacity: 0;
  transition: all 0.3s ease;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.5);
}

.demo-canvas.show .canvas-container {
  transform: scale(1);
  opacity: 1;
}

.canvas-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: #2a2a2a;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.canvas-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
}

.demo-canvas-element {
  width: 100%;
  height: 400rpx;
  background-color: #0a0a0a;
}

.canvas-controls {
  display: flex;
  justify-content: center;
  gap: 30rpx;
  padding: 20rpx;
  background-color: #2a2a2a;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.control-button {
  padding: 15rpx 30rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 25rpx;
  font-size: 24rpx;
  color: #ffffff;
  cursor: pointer;
  transition: background-color 0.3s ease;
}

.control-button:active {
  background-color: rgba(255, 255, 255, 0.2);
}

.control-button:nth-child(2) {
  background-color: #1677ff;
}

.control-button:nth-child(2):active {
  background-color: #409eff;
}

.demo-description {
  padding: 20rpx 24rpx;
  background-color: #2a2a2a;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.description-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.4;
}

/* 分享面板 */
.share-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background-color: #2a2a2a;
  border-radius: 30rpx 30rpx 0 0;
  padding: 30rpx 24rpx;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: 1000;
}

.share-panel.show {
  transform: translateY(0);
}

.share-panel .panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.share-panel .panel-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.share-panel .close-button {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.share-panel .close-button text {
  color: #ffffff;
  font-size: 24rpx;
}

.share-options {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.share-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  cursor: pointer;
}

.share-icon-wrapper {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  background-color: rgba(255, 255, 255, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.share-option-text {
  font-size: 24rpx;
  color: #ffffff;
}

/* 浮动添加按钮 */
.fab-button {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background-color: #1677ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(22, 119, 255, 0.4);
  z-index: 50;
  cursor: pointer;
  transition: transform 0.2s ease, background-color 0.2s ease;
}

.fab-button:active {
  transform: scale(0.95);
  background-color: #409eff;
}

.fab-icon {
  color: #ffffff;
  font-size: 48rpx;
  font-weight: bold;
  line-height: 1;
}

/* 添加节点面板 */
.add-node-panel {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 150;
  display: flex;
  justify-content: flex-end;
  pointer-events: none;
}

.add-node-panel.show {
  pointer-events: auto;
}

.add-node-panel .panel-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.add-node-panel.show .panel-mask {
  opacity: 1;
}

.add-node-content {
  width: 80%;
  height: 100%;
  background-color: #2a2a2a;
  transform: translateX(100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
}

.add-node-panel.show .add-node-content {
  transform: translateX(0);
}

.add-node-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.add-node-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.add-node-body {
  flex: 1;
  padding: 30rpx 24rpx;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 15rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  padding: 0 20rpx;
  color: #ffffff;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-picker {
  width: 100%;
  height: 80rpx;
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  padding: 0 20rpx;
  color: #ffffff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  padding: 20rpx;
  color: #ffffff;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.form-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  cursor: pointer;
  transition: opacity 0.2s ease;
}

.form-btn:active {
  opacity: 0.8;
}

.form-btn.cancel {
  background-color: rgba(255, 255, 255, 0.1);
  color: #ffffff;
}

.form-btn.confirm {
  background-color: #1677ff;
  color: #ffffff;
}

.note-empty {
  padding: 40rpx 0;
  text-align: center;
}

.note-empty-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 响应式调整 */
@media (max-width: 750rpx) {
  .panel-content,
  .add-node-content {
    width: 90%;
  }
  
  .share-options {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .canvas-container {
    width: 95%;
  }
  
  .demo-canvas-element {
    height: 300rpx;
  }
}
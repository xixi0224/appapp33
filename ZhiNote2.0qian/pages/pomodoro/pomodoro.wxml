<view class="container">
  <!-- 今日学习时长统计 -->
  <view class="today-stats">
    <text class="stats-label">今日学习时长</text>
    <text class="stats-value">{{todayTotalMinutes}} 分钟</text>
  </view>
  
  <!-- 已经专注的时间 -->
  <view class="elapsed-stats" wx:if="{{elapsedMinutes > 0}}">
    <text class="elapsed-label">本次专注</text>
    <text class="elapsed-value">{{elapsedMinutes}} 分钟</text>
  </view>
  
  <!-- 倒计时显示 -->
  <view class="timer-display">
    <view class="timer-circle">
      <text class="timer-text">{{formattedTime}}</text>
      <text class="timer-status">{{timerStatus}}</text>
    </view>
  </view>
  
  <!-- 控制按钮 -->
  <view class="control-buttons">
    <button wx:if="{{!isRunning}}" class="control-button start" bindtap="startTimer">开始</button>
    <button wx:else class="control-button pause" bindtap="pauseTimer">暂停</button>
    <button class="control-button reset" bindtap="resetTimer">重置</button>
  </view>
  
  <!-- 白噪音选择 -->
  <view class="noise-section">
    <text class="section-title">白噪音</text>
    <view class="noise-list">
      <view 
        wx:for="{{noiseList}}" 
        wx:key="id"
        class="noise-item {{selectedNoise === item.id ? 'selected' : ''}}"
        bindtap="selectNoise"
        data-id="{{item.id}}"
      >
        <text class="noise-icon">{{item.icon}}</text>
        <text class="noise-name">{{item.name}}</text>
      </view>
    </view>
  </view>
  
  <!-- 时间设置 -->
  <view class="time-section">
    <text class="section-title">时间设置</text>
    <view class="time-list">
      <view 
        wx:for="{{timeOptions}}" 
        wx:key="value"
        class="time-item {{selectedTime === item.value ? 'selected' : ''}}"
        bindtap="selectTime"
        data-value="{{item.value}}"
      >
        <text class="time-text">{{item.label}}</text>
      </view>
    </view>
  </view>
</view>
page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 40rpx;
  min-height: 100vh;
}

/* 今日学习时长统计 */
.today-stats {
  width: 100%;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  backdrop-filter: blur(10rpx);
}

.stats-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 10rpx;
}

.stats-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

/* 本次专注时间 */
.elapsed-stats {
  width: 100%;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 15rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.elapsed-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.elapsed-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFD700;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

/* 倒计时显示 */
.timer-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.timer-circle {
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 30rpx rgba(255, 255, 255, 0.3);
}

.timer-text {
  font-size: 120rpx;
  font-weight: bold;
  color: #ffffff;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.timer-status {
  font-size: 28rpx;
  color: #ffffff;
  margin-top: 20rpx;
}

/* 控制按钮 */
.control-buttons {
  display: flex;
  gap: 30rpx;
  margin-bottom: 60rpx;
}

.control-button {
  padding: 24rpx 60rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.control-button.start {
  background-color: #ffffff;
  color: #667eea;
}

.control-button.pause {
  background-color: #ffffff;
  color: #764ba2;
}

.control-button.reset {
  background-color: rgba(255, 255, 255, 0.3);
  color: #ffffff;
}

/* 白噪音选择 */
.noise-section {
  width: 100%;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 28rpx;
  color: #ffffff;
  margin-bottom: 20rpx;
  display: block;
}

.noise-list {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 15rpx;
}

.noise-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 15rpx;
  padding: 20rpx;
  transition: all 0.3s ease;
}

.noise-item.selected {
  background-color: rgba(255, 255, 255, 0.4);
  transform: scale(1.05);
}

.noise-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.noise-name {
  font-size: 20rpx;
  color: #ffffff;
}

/* 时间设置 */
.time-section {
  width: 100%;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 30rpx;
}

.time-list {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 15rpx;
}

.time-item {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 15rpx;
  padding: 20rpx;
  transition: all 0.3s ease;
}

.time-item.selected {
  background-color: rgba(255, 255, 255, 0.4);
  transform: scale(1.05);
}

.time-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: bold;
}

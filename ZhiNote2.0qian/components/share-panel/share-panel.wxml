<view class="share-panel" wx:if="{{show}}">
  <!-- 遮罩层 -->
  <view class="share-mask" bindtap="close"></view>
  
  <!-- 分享面板 -->
  <view class="share-content">
    <view class="share-header">
      <text class="share-title">分享到</text>
      <text class="share-close" bindtap="close">×</text>
    </view>
    
    <view class="share-options">
      <view class="share-item" bindtap="exportPdf">
        <view class="share-icon pdf">
          <text class="icon">📄</text>
        </view>
        <text class="share-text">导出PDF</text>
      </view>
      
      <view class="share-item" bindtap="exportChart">
        <view class="share-icon chart">
          <text class="icon">📊</text>
        </view>
        <text class="share-text">图谱截图</text>
      </view>
      
      <view class="share-item" bindtap="shareCard">
        <view class="share-icon card">
          <text class="icon">🎨</text>
        </view>
        <text class="share-text">分享卡片</text>
      </view>
      
      <view class="share-item" bindtap="generateQrCode">
        <view class="share-icon qrcode">
          <text class="icon">📱</text>
        </view>
        <text class="share-text">小程序码</text>
      </view>
    </view>
    
    <view class="share-footer">
      <button class="cancel-button" bindtap="close">取消</button>
    </view>
  </view>
</view>